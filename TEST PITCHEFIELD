<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pitchfield — Là où ton futur commence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0D1B2E;--navy-mid:#1A3A5C;--navy-light:#243F60;
  --gold:#C9A84C;--gold-light:#E8C96A;--gold-pale:#FFF8E7;
  --cream:#F9F6F0;--white:#FFFFFF;
  --text-dark:#0D1B2E;--text-mid:#4A5568;--text-light:#8898A8;
  --border:rgba(13,27,46,0.1);--green:#1E7E34;--green-light:#D4EDDA;
  --red:#E24B4A;--sidebar-w:240px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}

/* ── RESPONSIVE UTILITIES ── */
@media(max-width:768px){
  .hide-mobile{display:none!important;}
  .nav-links{display:none!important;}
  .hero{padding:100px 24px 60px!important;flex-direction:column!important;}
  .hero-stats{position:static!important;transform:none!important;flex-direction:row!important;flex-wrap:wrap!important;gap:12px!important;margin-top:40px!important;width:100%!important;}
  .hero h1{font-size:36px!important;letter-spacing:-1px!important;}
  .features{padding:60px 24px!important;}
  .features-grid{grid-template-columns:1fr!important;}
  .reviews{padding:60px 24px!important;}
  .reviews-grid{grid-template-columns:1fr!important;}
  .offers-page{padding:80px 16px 40px!important;}
  .offers-grid{grid-template-columns:1fr!important;}
  .b2b-grid{grid-template-columns:1fr!important;}
  .commission-banner{flex-direction:column!important;text-align:center!important;}
  .login-page{flex-direction:column!important;}
  .login-left{padding:60px 24px 40px!important;}
  .login-right{padding:40px 24px!important;}
  .app-layout{flex-direction:column!important;}
  .sidebar{width:100%!important;position:relative!important;top:auto!important;height:auto!important;padding:12px 0!important;}
  .sidebar-user{display:none!important;}
  .sidebar-nav{display:flex!important;flex-wrap:wrap!important;padding:0 8px!important;gap:4px!important;}
  .sidebar-nav li a{padding:8px 12px!important;font-size:12px!important;border-radius:8px!important;}
  .sidebar-section{display:none!important;}
  .main-content{margin-left:0!important;padding:16px!important;}
  .dash-kpis{grid-template-columns:1fr 1fr!important;}
  .dash-grid{grid-template-columns:1fr!important;}
  .domains-grid{grid-template-columns:1fr 1fr!important;}
  .favs-grid{grid-template-columns:1fr!important;}
  .messages-layout{grid-template-columns:1fr!important;height:auto!important;}
  .messages-list{display:none!important;}
  .rdv-grid{grid-template-columns:1fr!important;}
  .courses-grid{grid-template-columns:1fr!important;}
  .footer-grid{grid-template-columns:1fr 1fr!important;}
  .footer-brand{grid-column:1/-1!important;}
  .section-title{font-size:28px!important;}
  .nav-mobile-btn{display:flex!important;}
  .mobile-menu{display:block!important;}
}

/* ── NAV ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(13,27,46,0.97);backdrop-filter:blur(12px);
  height:64px;display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;border-bottom:1px solid rgba(201,168,76,0.2);
}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--gold);letter-spacing:-0.5px;cursor:pointer;}
.nav-logo span{color:var(--white);}
.nav-links{display:flex;gap:32px;align-items:center;}
.nav-links a{color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;cursor:pointer;transition:color .2s;}
.nav-links a:hover{color:var(--white);}
.nav-cta{background:var(--gold);color:var(--navy);padding:9px 22px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;border:none;}
.nav-mobile-btn{display:none;background:none;border:none;cursor:pointer;flex-direction:column;gap:5px;}
.nav-mobile-btn span{display:block;width:22px;height:2px;background:var(--white);}
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;background:var(--navy);z-index:99;padding:16px;}
.mobile-menu a{display:block;padding:12px 16px;color:rgba(255,255,255,0.8);text-decoration:none;}

/* ── PAGES ── */
.page{display:none;min-height:100vh;padding-top:64px;}
.page.active{display:block;}

/* ── SIDEBAR LAYOUT ── */
.app-layout{display:flex;min-height:calc(100vh - 64px);}
.sidebar{
  width:var(--sidebar-w);background:var(--navy);flex-shrink:0;position:fixed;
  top:64px;bottom:0;left:0;overflow-y:auto;padding:24px 0;
  border-right:1px solid rgba(255,255,255,0.06);
}
.sidebar-user{padding:0 20px 24px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:16px;}
.sidebar-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;color:var(--navy);}
.sidebar-name{font-size:14px;font-weight:500;color:var(--white);margin-top:10px;}
.sidebar-role{font-size:12px;color:rgba(255,255,255,0.45);}
.sidebar-nav{list-style:none;padding:0 8px;}
.sidebar-nav li a{
  display:flex;align-items:center;gap:12px;padding:10px 12px;
  border-radius:10px;color:rgba(255,255,255,0.6);text-decoration:none;
  font-size:13.5px;cursor:pointer;
}
.sidebar-nav li a.active{background:rgba(201,168,76,0.15);color:var(--gold);}
.sidebar-section{font-size:10px;font-weight:500;color:rgba(255,255,255,0.25);text-transform:uppercase;padding:16px 20px 6px;}
.main-content{margin-left:var(--sidebar-w);flex:1;padding:32px 36px;background:var(--cream);}

/* ── ROLES ADMIN / USER ── */
.admin-only { display: none; }
body.role-admin .admin-only { display: block; }
.role-badge-admin { display:none; background:var(--gold); color:var(--navy); font-size:10px; font-weight:700; padding:2px 8px; border-radius:50px; }
body.role-admin .role-badge-admin { display:inline-block; }

/* ── DASHBOARD ── */
.dash-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.kpi-card{background:var(--white);border-radius:16px;padding:20px;border:1px solid var(--border);}
.kpi-value{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;}

/* ── ACADEMY DYNAMIQUE ── */
.academy-admin-panel { background:var(--navy); border-radius:16px; padding:24px; margin-bottom:24px; border:2px solid var(--gold); }
.academy-admin-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; color:var(--white); margin-bottom:16px; display:flex; align-items:center; gap:10px; }
.admin-module-item { background:rgba(255,255,255,0.05); border-radius:10px; padding:12px; display:flex; align-items:center; gap:12px; margin-bottom:8px; }
.admin-add-btn { background:var(--gold); color:var(--navy); border:none; padding:6px 12px; border-radius:50px; font-size:12px; font-weight:600; cursor:pointer; }

.academy-hero{background:var(--navy);border-radius:20px;padding:40px;margin-bottom:24px;color:white;}
.academy-toolbar{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
.academy-search input{padding:10px 16px;border-radius:50px;border:1px solid var(--border);width:300px;}
.academy-cats{display:flex;gap:8px;margin-bottom:20px;}
.academy-cat{padding:8px 16px;border-radius:50px;background:white;border:1px solid var(--border);cursor:pointer;font-size:13px;}
.academy-cat.active{background:var(--navy);color:white;}

.courses-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.course-card{background:white;border-radius:20px;overflow:hidden;border:1px solid var(--border);transition:0.3s;display:flex;flex-direction:column;}
.course-thumb{height:140px;display:flex;align-items:center;justify-content:center;font-size:40px;background:var(--navy-light);position:relative;}
.course-body{padding:20px;flex:1;}
.course-title{font-family:'Syne',sans-serif;font-weight:700;margin-bottom:10px;}

.video-player-section { margin-top:15px; border-top:1px solid var(--border); padding-top:12px; display:none; }
.video-player-section.has-videos { display:block; }
.video-pill { display:inline-flex; align-items:center; gap:6px; background:var(--green-light); color:var(--green); font-size:11px; padding:4px 12px; border-radius:50px; cursor:pointer; margin:2px; font-weight:600; }
.video-embed-area { margin-top:10px; border-radius:12px; overflow:hidden; display:none; background:#000; }

/* ── RECHERCHE & FAVORIS ── */
.domain-card{background:white;padding:24px;border-radius:16px;border:1px solid var(--border);cursor:pointer;}
.fav-card{background:white;padding:20px;border-radius:16px;border:1px solid var(--border);display:flex;gap:15px;}
.fav-avatar{width:50px;height:50px;border-radius:12px;background:var(--navy);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700;}

/* ── MESSAGES ── */
.messages-layout{display:grid;grid-template-columns:280px 1fr;background:white;border-radius:20px;height:600px;overflow:hidden;}
.messages-list{border-right:1px solid var(--border);overflow-y:auto;}
.conv-item{padding:15px;border-bottom:1px solid var(--border);cursor:pointer;}
.chat-area{display:flex;flex-direction:column;height:100%;}
.chat-messages{flex:1;padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;}
.msg-bubble{padding:10px 15px;border-radius:15px;max-width:70%;font-size:14px;}
.msg-in .msg-bubble{background:var(--cream);}
.msg-out{align-self:flex-end;}
.msg-out .msg-bubble{background:var(--navy);color:white;}

/* ── RDV ── */
.calendar-card{background:white;padding:24px;border-radius:20px;}
.cal-days{display:grid;grid-template-columns:repeat(7,1fr);border:1px solid var(--border);}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;cursor:pointer;border:0.5px solid var(--border);}
.cal-day.today{background:var(--navy);color:white;}
.cal-day.has-event::after{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%;position:absolute;bottom:5px;}

/* ── MODALES ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1000;align-items:center;justify-content:center;}
.modal-content{background:white;padding:32px;border-radius:24px;width:500px;max-width:90%;position:relative;}

/* ── FORM ── */
.form-group{margin-bottom:16px;}
.form-label{display:block;font-size:13px;font-weight:600;margin-bottom:6px;}
.form-input, .form-select{width:100%;padding:12px;border-radius:10px;border:1px solid var(--border);font-family:inherit;}
.form-btn{width:100%;padding:14px;background:var(--navy);color:white;border:none;border-radius:50px;font-weight:600;cursor:pointer;}

</style>
</head>
