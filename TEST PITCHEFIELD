.video-embed-area { margin-top:10px; border-radius:12px; overflow:hidden; display:none; background:#000; }

/* ── RECHERCHE & FAVORIS ── */
.domain-card{background:white;padding:24px;border-radius:16px;border:1px solid var(--border);cursor:pointer;}
.fav-card{background:white;padding:20px;border-radius:16px;border:1px solid var(--border);display:flex;gap:15px;}
.fav-avatar{width:50px;height:50px;border-radius:12px;background:var(--navy);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700;}

/* ── MESSAGES ── */
.messages-layout{display:grid;grid-template-columns:280px 1fr;background:white;border-radius:20px;height:600px;overflow:hidden;}
.messages-list{border-right:1px solid var(--border);overflow-y:auto;}
.conv-item{padding:15px;border-bottom:1px solid var(--border);cursor:pointer;}
.chat-area{display:flex;flex-direction:column;height:100%;}
.chat-messages{flex:1;padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;}
.msg-bubble{padding:10px 15px;border-radius:15px;max-width:70%;font-size:14px;}
.msg-in .msg-bubble{background:var(--cream);}
.msg-out{align-self:flex-end;}
.msg-out .msg-bubble{background:var(--navy);color:white;}

/* ── RDV ── */
.calendar-card{background:white;padding:24px;border-radius:20px;}
.cal-days{display:grid;grid-template-columns:repeat(7,1fr);border:1px solid var(--border);}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;cursor:pointer;border:0.5px solid var(--border);}
.cal-day.today{background:var(--navy);color:white;}
.cal-day.has-event::after{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%;position:absolute;bottom:5px;}

/* ── MODALES ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1000;align-items:center;justify-content:center;}
.modal-content{background:white;padding:32px;border-radius:24px;width:500px;max-width:90%;position:relative;}

/* ── FORM ── */
.form-group{margin-bottom:16px;}
.form-label{display:block;font-size:13px;font-weight:600;margin-bottom:6px;}
.form-input, .form-select{width:100%;padding:12px;border-radius:10px;border:1px solid var(--border);font-family:inherit;}
.form-btn{width:100%;padding:14px;background:var(--navy);color:white;border:none;border-radius:50px;font-weight:600;cursor:pointer;}

</style>
