<script>
// ── NAV ──────────────────────────────────────────────────────
var mobileMenuOpen = false;
function toggleMobileMenu(){
  mobileMenuOpen = !mobileMenuOpen;
  document.getElementById('mobile-menu').style.display = mobileMenuOpen ? 'block' : 'none';
}
function closeMobileMenu(){
  mobileMenuOpen = false;
  document.getElementById('mobile-menu').style.display = 'none';
}

// ── ROUTING ──────────────────────────────────────────────────
var APP_PAGES = ['dashboard','recherche','favoris','messages','rdv','academy'];
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  closeMobileMenu();
  if(APP_PAGES.indexOf(name) !== -1){
    document.getElementById('page-app').classList.add('active');
    showAppPage(name);
  } else {
    var pg = document.getElementById('page-'+name);
    if(pg) pg.classList.add('active');
  }
  window.scrollTo(0,0);
}
function showApp(){ showPage('dashboard'); }
function showAppPage(name){
  document.querySelectorAll('[id^="app-"]').forEach(p=>p.style.display='none');
  var el = document.getElementById('app-'+name);
  if(el) el.style.display='block';
  document.querySelectorAll('.sidebar-nav li a').forEach(a=>a.classList.remove('active'));
  var nav = document.getElementById('nav-'+name);
  if(nav) nav.classList.add('active');
}

// ── TABS LOGIN ────────────────────────────────────────────────
function switchTab(tab){
  document.querySelectorAll('.login-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  document.getElementById('login-fields').style.display   = tab==='login'    ? 'block' : 'none';
  document.getElementById('register-fields').style.display = tab==='register' ? 'block' : 'none';
}

// ── DOMAINES ─────────────────────────────────────────────────
function filterDomains(cat,el){
  document.querySelectorAll('.filter-tag').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.domain-card').forEach(c=>{
    c.style.display=(cat==='all'||c.dataset.cat===cat)?'block':'none';
  });
}
function searchDomains(){
  var q = document.getElementById('search-input').value.toLowerCase();
  document.querySelectorAll('.domain-card').forEach(c=>{
    var txt = c.textContent.toLowerCase();
    c.style.display = (!q || txt.includes(q)) ? 'block' : 'none';
  });
}

// ── ACADEMY FILTERS ──────────────────────────────────────────
var currentAcademyCat = 'all';
function setAcademyCat(cat,el){
  currentAcademyCat = cat;
  document.querySelectorAll('.academy-cat').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  filterAcademy();
}
function filterAcademy(){
  var q     = (document.getElementById('academy-search-input').value||'').toLowerCase();
  var level = document.getElementById('level-filter').value;
  var cards = document.querySelectorAll('.course-card');
  var visible = 0;
  cards.forEach(c=>{
    var matchCat   = currentAcademyCat==='all' || c.dataset.cat===currentAcademyCat;
    var matchLevel = !level || c.dataset.level===level;
    var matchQ     = !q || c.dataset.title.toLowerCase().includes(q) || c.textContent.toLowerCase().includes(q);
    var show = matchCat && matchLevel && matchQ;
    c.style.display = show ? 'flex' : 'none';
    if(show) visible++;
  });
