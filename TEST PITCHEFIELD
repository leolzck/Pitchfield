function openAddVideo(courseTitle){
  document.getElementById('vid-course-label').textContent = 'Module : ' + courseTitle;
  document.getElementById('vid-title').value = '';
  document.getElementById('vid-url').value   = '';
  document.getElementById('vid-dur').value   = '';
  document.getElementById('vid-preview').style.display = 'none';
  document.getElementById('vid-preview-msg').style.display = 'none';
  mOpen('video-modal');
}

function autoPreview(){
  var url = document.getElementById('vid-url').value.trim();
  if(!url){ document.getElementById('vid-preview').style.display='none'; return; }
  var ytM = url.match(/(?:v=|youtu\.be\/)?([\w-]{11})(?:$|\?|&)/);
  var viM = url.match(/vimeo\.com\/(\d+)/);
  var ytM2= url.match(/(?:v=|youtu\.be\/)([\w-]{11})/);
  var prev= document.getElementById('vid-preview');
  var msg = document.getElementById('vid-preview-msg');
  if(ytM2){
    prev.innerHTML='<iframe width="100%" height="200" src="https://www.youtube.com/embed/'+ytM2[1]+'" frameborder="0" allowfullscreen style="border-radius:10px;display:block;"></iframe>';
    prev.style.display='block'; msg.style.display='none';
  } else if(viM){
    prev.innerHTML='<iframe width="100%" height="200" src="https://player.vimeo.com/video/'+viM[1]+'" frameborder="0" allowfullscreen style="border-radius:10px;display:block;"></iframe>';
    prev.style.display='block'; msg.style.display='none';
  } else if(url.length>8){
    prev.style.display='none';
    msg.textContent='Lien non reconnu pour la prévisualisation — il sera quand même enregistré.';
    msg.style.display='block';
  }
}

function saveVideo(){
  var title  = document.getElementById('vid-title').value.trim();
  var url    = document.getElementById('vid-url').value.trim();
  var dur    = document.getElementById('vid-dur').value.trim();
  var course = document.getElementById('vid-course-label').textContent.replace('Module : ','');
  if(!title||!url){ alert('Veuillez remplir le titre et le lien.'); return; }
  if(!videoDB[course]) videoDB[course] = [];
  videoDB[course].push({ title:title, url:url, dur:dur });
  mClose('video-modal');
  // Rebuild admin panel
  if(currentUser && currentUser.role==='admin') buildAdminPanel();
  // Mettre à jour la card user avec le lecteur
  updateCourseCard(course);
  // Feedback
  showToast('Vidéo "'+title+'" publiée dans "'+course+'" !');
}

// ── USER : LECTEUR VIDÉO SUR LES CARDS ───────────────────────
function updateCourseCard(courseTitle){
  document.querySelectorAll('.course-card').forEach(function(card){
    var t = card.dataset.title || card.querySelector('.course-title').textContent;
    if(t !== courseTitle) return;
    var vids = videoDB[t] || [];
    // Chercher ou créer la section lecteur
    var section = card.querySelector('.video-player-section');
    if(!section){
      section = document.createElement('div');
      section.className = 'video-player-section';
      card.querySelector('.course-body').appendChild(section);
    }
    if(vids.length === 0){
      section.classList.remove('has-videos');
      section.innerHTML = '';
      return;
    }
    section.classList.add('has-videos');
    // Construire les pills + zone embed
    // Store card index for pill data-attributes
    var allCards = Array.from(document.querySelectorAll('.course-card'));
    var cIdx = allCards.findIndex(function(c){ return (c.dataset.title||c.querySelector('.course-title').textContent)===courseTitle; });
    window._buildCourseIdx = cIdx;
    var pillsHtml = vids.map(function(v,i){
      return '<span class="video-pill" data-course-idx="' + window._buildCourseIdx + '" data-vid-idx="' + i + '" onclick="playVideoByAttr(this)">&#9658; ' + (v.dur ? v.dur + ' · ' : '') + v.title + '</span>';
    }).join('');
    section.innerHTML =
      '<div style="font-size:11px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;">'+vids.length+' vidéo'+(vids.length>1?'s':'')+' disponible'+(vids.length>1?'s':'')+'</div>'+
      '<div>'+pillsHtml+'</div>'+
      '<div class="video-embed-area" id="embed-'+courseTitle.replace(/[^a-z0-9]/gi,'_')+'"></div>';
    // Badge vert sur la card
    var badge = card.querySelector('.vid-count-badge');
    if(!badge){
      badge = document.createElement('span');
      badge.className = 'vid-count-badge';
      badge.style.cssText = 'display:inline-block;margin-left:6px;background:rgba(30,126,52,0.12);color:var(--green);font-size:11px;padding:2px 8px;border-radius:50px;';
      var tag = card.querySelector('.course-tag');
      if(tag) tag.after(badge);
    }
    badge.textContent = vids.length+(vids.length>1?' vidéos':' vidéo');
  });
}

function playVideoByAttr(span){
  var courseIdx = span.getAttribute('data-course-idx');
  var vidIdx    = parseInt(span.getAttribute('data-vid-idx'));
  var cards     = Array.from(document.querySelectorAll('.course-card'));
  var card      = cards[courseIdx];
  if(!card) return;
  var t = card.dataset.title || card.querySelector('.course-title').textContent;
  playVideo(span, t, vidIdx);
}
function playVideo(pillEl, courseTitle, idx){
  var vids = videoDB[courseTitle] || [];
  var v = vids[idx];
  if(!v) return;
  var embedId = 'embed-'+courseTitle.replace(/[^a-z0-9]/gi,'_');
  var area = document.getElementById(embedId);
  if(!area) return;
  // Toggle : si déjà ouvert et même vidéo, fermer
  if(area.dataset.active == idx && area.style.display==='block'){
    area.style.display = 'none';
    area.dataset.active = '';
    pillEl.style.background=''; pillEl.style.color='';
    return;
  }
  // Marquer pill active
  area.closest('.video-player-section').querySelectorAll('.video-pill').forEach(function(p){ p.style.background=''; p.style.color=''; });
  pillEl.style.background='var(--green)'; pillEl.style.color='white';
  area.dataset.active = idx;
  var url = v.url;
  var ytM = url.match(/(?:v=|youtu\.be\/)([\w-]{11})/);
  var viM = url.match(/vimeo\.com\/(\d+)/);
  var html = '';
  if(ytM){
    html = '<iframe width="100%" height="240" src="https://www.youtube.com/embed/'+ytM[1]+'?autoplay=1" frameborder="0" allow="autoplay;encrypted-media" allowfullscreen style="border-radius:10px;display:block;"></iframe>';
  } else if(viM){
    html = '<iframe width="100%" height="240" src="https://player.vimeo.com/video/'+viM[1]+'?autoplay=1" frameborder="0" allow="autoplay" allowfullscreen style="border-radius:10px;display:block;"></iframe>';
  } else {
    html = '<div style="padding:14px;background:var(--cream);border-radius:10px;font-size:13px;"><a href="'+url+'" target="_blank" style="color:var(--navy);">▶ Ouvrir la vidéo dans un nouvel onglet →</a></div>';
  }
  area.innerHTML = html;
  area.style.display = 'block';
}

// ── TOAST ─────────────────────────────────────────────────────
function showToast(msg){
  var t = document.getElementById('toast-notif');
  if(!t){
    t = document.createElement('div');
    t.id = 'toast-notif';
    t.style.cssText='position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:var(--navy);color:var(--white);padding:12px 24px;border-radius:50px;font-size:14px;z-index:999;border:1px solid var(--gold);box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:opacity .3s;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._timer);
  t._timer = setTimeout(function(){ t.style.opacity='0'; }, 3000);
}

