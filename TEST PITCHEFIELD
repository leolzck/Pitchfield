<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pitchfield — Plateforme Intégrée v4</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #0D1B2E; --navy-mid: #1A3A5C; --gold: #C9A84C; 
            --cream: #F9F6F0; --white: #FFFFFF; --red: #E24B4A; --green: #1E7E34;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--navy); transition: 0.3s; }
        
        /* Visibilité par Rôles */
        .admin-only, .pro-only, .user-only { display: none; }
        body.role-admin .admin-only { display: block; }
        body.role-pro .pro-only { display: block; }
        body.role-user .user-only { display: block; }

        /* Layout Global */
        .nav { background: var(--navy); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; color: white; position: fixed; width: 100%; z-index: 1000; border-bottom: 1px solid rgba(201,168,76,0.2); }
        .app-layout { display: flex; padding-top: 60px; min-height: 100vh; }
        .sidebar { width: 250px; background: var(--navy); color: white; padding: 2rem 1rem; position: fixed; height: 100vh; border-right: 1px solid rgba(255,255,255,0.05); }
        .main-content { margin-left: 250px; padding: 2rem; width: calc(100% - 250px); }

        /* Composants UI */
        .card { background: white; padding: 1.5rem; border-radius: 15px; border: 1px solid rgba(0,0,0,0.1); margin-bottom: 1rem; position: relative; transition: 0.3s; }
        .card:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .btn { padding: 0.6rem 1.2rem; border-radius: 50px; border: none; cursor: pointer; font-weight: 600; transition: 0.3s; font-family: 'DM Sans'; text-align: center; }
        .btn-gold { background: var(--gold); color: var(--navy); }
        .btn-navy { background: var(--navy); color: white; }
        
        /* Badges & Tags */
        .badge-verified { display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; background: #0077B5; color: white; border-radius: 50%; font-size: 10px; margin-left: 5px; vertical-align: middle; font-weight: bold; }
        .tag { background: var(--cream); padding: 3px 10px; border-radius: 50px; font-size: 0.7rem; font-weight: bold; color: var(--navy-mid); }

        /* Simulateur de Rôle Safari */
        #test-panel { position: fixed; bottom: 20px; right: 20px; background: white; padding: 15px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); z-index: 2000; border: 2px solid var(--gold); width: 200px; }

        /* Messagerie & Bot */
        .chat-box { height: 250px; overflow-y: auto; background: #f4f7f6; padding: 15px; border-radius: 10px; display: flex; flex-direction: column; gap: 10px; border: 1px solid #ddd; }
        .msg { padding: 10px; border-radius: 10px; max-width: 80%; font-size: 0.85rem; line-height: 1.4; }
        .msg-bot { background: var(--navy); color: white; align-self: flex-start; }
        .msg-user { background: var(--gold); color: var(--navy); align-self: flex-end; }

        /* Calendrier */
        .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; background: white; padding: 10px; border-radius: 10px; border: 1px solid #ddd; }
        .cal-day { aspect-ratio: 1; border: 1px solid #eee; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.8rem; border-radius: 5px; }
        .cal-day.blocked { background: #ffebee; color: var(--red); cursor: not-allowed; text-decoration: line-through; }
        .cal-day.selected { background: var(--gold); color: var(--navy); font-weight: bold; }
    </style>
</head>
<body class="role-user">

<div id="test-panel">
    <strong style="font-size: 0.7rem; display: block; margin-bottom: 10px; text-transform: uppercase; color: #666;">🛠 Simulateur de Compte</strong>
    <div style="display: grid; grid-template-columns: 1fr; gap: 5px;">
        <button class="btn" style="font-size: 0.65rem; padding: 6px;" onclick="setRole('user')">📱 Compte Étudiant</button>
        <button class="btn" style="font-size: 0.65rem; padding: 6px;" onclick="setRole('pro')">💼 Compte Pro</button>
        <button class="btn" style="font-size: 0.65rem; padding: 6px;" onclick="setRole('admin')">👑 Compte Admin</button>
    </div>
</div>

<nav class="nav">
    <div style="font-family: Syne; font-size: 1.4rem; font-weight: 800; cursor: pointer;" onclick="showPage('dash')">Pitch<span style="color:var(--gold)">field</span></div>
    <div id="user-tag" style="font-size: 0.75rem; background: rgba(255,255,255,0.1); padding: 5px 15px; border-radius: 50px;">Mode : Étudiant</div>
</nav>

<div class="app-layout">
    <aside class="sidebar">
        <ul style="list-style: none;">
            <li onclick="showPage('dash')" style="cursor:pointer; padding: 12px; border-radius: 8px;">🏠 Dashboard</li>
            <li onclick="showPage('explore')" style="cursor:pointer; padding: 12px;">🔍 Explorer les Pros</li>
            <li onclick="showPage('stages')" style="cursor:pointer; padding: 12px;">💼 Stages & Alternances</li>
            <li onclick="showPage('rdv')" style="cursor:pointer; padding: 12px;">📅 Calendrier & RDV</li>
            <li onclick="showPage('msg')" style="cursor:pointer; padding: 12px;">💬 PitchBot Assistant</li>
            <li onclick="showPage('academy')" style="cursor:pointer; padding: 12px;">🎓 Académie & Fiches</li>
            <hr style="opacity: 0.1; margin: 20px 0;">
            <li onclick="openLegal('mentions')" style="font-size: 0.75rem; opacity: 0.6; cursor:pointer; padding: 5px 12px;">Mentions Légales</li>
            <li onclick="openLegal('cgu')" style="font-size: 0.75rem; opacity: 0.6; cursor:pointer; padding: 5px 12px;">CGU / CGV / Confidentialité</li>
        </ul>
    </aside>

    <main class="main-content">
        <div id="page-dash" class="page">
            <h1 style="font-family: Syne; margin-bottom: 20px;">Bienvenue sur Pitchfield</h1>
            
            <div class="admin-only card" style="background: var(--navy); color: white; border: 2px solid var(--gold);">
                <h3>Console d'Administration 👑</h3>
                <p style="margin: 10px 0; font-size: 0.85rem; opacity: 0.8;">Utilisez les boutons ci-dessous pour peupler la plateforme.</p>
                <div style="display: flex; gap: 10px;">
                    <button class="btn btn-gold" style="font-size: 0.8rem;" onclick="addProPrompt()">+ Ajouter un Mentor Pro</button>
                    <button class="btn btn-navy" style="border: 1px solid white; font-size: 0.8rem;" onclick="addFichePrompt()">+ Publier une Fiche</button>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
                <div class="card">
                    <h4>⭐ Mes Pros Favoris</h4>
                    <div id="fav-list" style="margin-top: 15px; display: flex; flex-wrap: wrap; gap: 8px;"></div>
                </div>
                <div class="card">
                    <h4>📅 Prochain RDV</h4>
                    <div id="next-rdv" style="margin-top: 15px; font-size: 0.9rem; font-weight: bold; color: var(--gold);">Aucune session planifiée.</div>
                </div>
            </div>
        </div>

        <div id="page-explore" class="page" style="display:none;">
            <h1 style="font-family: Syne; margin-bottom: 20px;">Nos Mentors & Professionnels</h1>
            <div id="pro-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;"></div>
        </div>

        <div id="page-stages" class="page" style="display:none;">
            <h1 style="font-family: Syne; margin-bottom: 10px;">Recherche de Stages</h1>
            <p style="margin-bottom: 25px; color: #666;">Accédez aux raccourcis des portails officiels par domaine.</p>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="card" onclick="window.open('https://www.thalesgroup.com/fr/carrieres')">
                    <span class="tag">DÉFENSE</span>
                    <h3 style="margin-top:10px;">🛡️ Thales & Aéronautique</h3>
                    <p style="font-size: 0.8rem; margin-top: 5px; opacity: 0.7;">Portails recrutement défense et hautes technologies.</p>
                </div>
                <div class="card" onclick="window.open('https://www.efinancialcareers.fr/')">
                    <span class="tag">FINANCE</span>
                    <h3 style="margin-top:10px;">💰 Finance & Audit</h3>
                    <p style="font-size: 0.8rem; margin-top: 5px; opacity: 0.7;">Banques, cabinets de conseil et trading.</p>
                </div>
                <div class="card" onclick="window.open('https://www.welcometothejungle.com/')">
                    <span class="tag">TECH</span>
                    <h3 style="margin-top:10px;">💻 Tech & Startup</h3>
                    <p style="font-size: 0.8rem; margin-top: 5px; opacity: 0.7;">Développement, IA et écosystème Startup.</p>
                </div>
                <div class="card" onclick="window.open('https://www.bourseduloisir.fr')">
                    <span class="tag">IMMOBILIER</span>
                    <h3 style="margin-top:10px;">🏠 Investissement</h3>
                    <p style="font-size: 0.8rem; margin-top: 5px; opacity: 0.7;">Réseau immobilier et business en ligne.</p>
                </div>
            </div>
        </div>

        <div id="page-academy" class="page" style="display:none;">
            <h1 style="font-family: Syne; margin-bottom: 20px;">Fiches de Révision & Cours</h1>
            <div id="fiches-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;"></div>
        </div>

        <div id="page-rdv" class="page" style="display:none;">
            <h1 style="font-family: Syne;">Prendre un Rendez-vous</h1>
            <p style="margin-bottom: 20px; font-size: 0.9rem;">Sélectionnez une date libre (en blanc). Les dates en rouge sont bloquées par l'admin.</p>
            <div class="cal-grid" id="calendar"></div>
            <div id="rdv-box" class="card" style="margin-top:20px; display:none; border-color: var(--gold);">
                <h4>Confirmer la session</h4>
                <p id="rdv-text" style="font-size: 0.85rem; margin: 10px 0;"></p>
                <button class="btn btn-gold" onclick="confirmBooking()">Confirmer le RDV</button>
            </div>
        </div>

        <div id="page-msg" class="page" style="display:none;">
            <h1 style="font-family: Syne;">PitchBot Assistant</h1>
            <div class="card">
                <div class="chat-box" id="chat-box">
                    <div class="msg msg-bot">Bonjour ! Je suis PitchBot. Pose-moi une question sur ton CV, tes entretiens ou nos fiches.</div>
                </div>
                <div style="margin-top: 15px; display: flex; gap: 10px;">
                    <input type="text" id="chat-input" placeholder="CV, Fiches, Stages..." style="flex:1; padding: 12px; border-radius: 10px; border: 1px solid #ccc;">
                    <button class="btn btn-navy" onclick="askBot()">Envoyer</button>
                </div>
            </div>
        </div>
    </main>
</div>

<div id="modal-legal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:2000; align-items:center; justify-content:center; padding:20px;">
    <div class="card" style="max-width:600px; width:100%; max-height:85vh; overflow-y:auto;">
        <div id="legal-body"></div>
        <button class="btn btn-navy" onclick="closeLegal()" style="margin-top:20px; width:100%;">Fermer</button>
    </div>
</div>

<script>
    // --- BASE DE DONNÉES SIMULÉE (LOCALSTORAGE) ---
    let db = JSON.parse(localStorage.getItem('pitchfield_final_v1')) || {
        pros: [
            { id: 1, name: "Marie Andrieu", job: "RH @ Thales", verified: true, fav: false },
            { id: 2, name: "Léo Leszczynski", job: "Ingénieur Systèmes", verified: true, fav: false },
            { id: 3, name: "Julien Faure", job: "Consultant Finance", verified: false, fav: false }
        ],
        fiches: [
            { id: 1, title: "Optimiser son CV pour l'IA", content: "Utilisez des mots-clés ATS, évitez les colonnes complexes." },
            { id: 2, title: "L'art du Pitch en 2 minutes", content: "Structure : Accroche, Parcours, Objectif, Appel à l'action." }
        ],
        blockedDays: [1, 2, 8, 15, 22, 29] // Indisponibilités (ex: Dimanches)
    };

    function save() { localStorage.setItem('pitchfield_final_v1', JSON.stringify(db)); }

    // --- SYSTÈME DE RÔLES & NAVIGATION ---
    function setRole(role) {
        document.body.className = 'role-' + role;
        document.getElementById('user-tag').innerText = "Mode : " + role.toUpperCase();
        renderPros(); 
    }

    function showPage(id) {
        document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
        document.getElementById('page-' + id).style.display = 'block';
        if(id === 'explore') renderPros();
        if(id === 'academy') renderFiches();
        if(id === 'rdv') renderCalendar();
        if(id === 'dash') renderFavs();
        window.scrollTo(0,0);
    }

    // --- GESTION DES PROFESSIONNELS (PROS) ---
    function renderPros() {
        const grid = document.getElementById('pro-grid');
        grid.innerHTML = db.pros.map(p => `
            <div class="card">
                <span style="float:right; cursor:pointer; color:${p.fav ? 'var(--red)' : '#ccc'}" onclick="toggleFav(${p.id})">❤</span>
                <strong>${p.name} ${p.verified ? '<span class="badge-verified" title="Certifié Pitchfield">✓</span>' : ''}</strong><br>
                <small style="color: #666;">${p.job}</small>
                
                <div class="admin-only" style="margin-top:12px; border-top:1px solid #eee; padding-top:10px;">
                    <button class="btn" style="font-size:0.6rem; padding:5px 10px; background:${p.verified ? '#f0f0f0' : 'var(--green)'}; color:${p.verified ? '#333' : 'white'}" onclick="verifyPro(${p.id})">
                        ${p.verified ? 'Retirer Certification' : 'Certifier le Pro'}
                    </button>
                </div>
                
                <button class="btn btn-navy" style="width:100%; margin-top:10px; font-size:0.75rem;" onclick="showPage('msg')">Contacter</button>
            </div>
        `).join('');
    }

    function verifyPro(id) {
        const pro = db.pros.find(p => p.id === id);
        pro.verified = !pro.verified;
        save(); renderPros();
    }

    function addProPrompt() {
        const n = prompt("Nom du professionnel :");
        const j = prompt("Poste / Entreprise :");
        if(n && j) { db.pros.push({id: Date.now(), name: n, job: j, verified: false, fav: false}); save(); renderPros(); }
    }

    // --- FAVORIS ---
    function toggleFav(id) {
        const pro = db.pros.find(p => p.id === id);
        pro.fav = !pro.fav;
        save(); renderPros(); renderFavs();
    }

    function renderFavs() {
        const list = document.getElementById('fav-list');
        const favs = db.pros.filter(p => p.fav);
        list.innerHTML = favs.length ? favs.map(f => `<div class="btn" style="background:var(--navy); color:white; font-size:0.7rem; padding: 5px 12px;">${f.name}</div>`).join('') : "<span style='color:#999; font-size:0.8rem;'>Ajoutez des mentors en favoris via l'onglet Recherche.</span>";
    }

    // --- ACADÉMIE & FICHES ---
    function renderFiches() {
        const grid = document.getElementById('fiches-grid');
        grid.innerHTML = db.fiches.map(f => `
            <div class="card" style="border-left: 5px solid var(--gold);">
                <strong>${f.title}</strong>
                <p style="font-size:0.75rem; margin:10px 0; opacity:0.7;">Fiche stratégique Pitchfield Academy.</p>
                <button class="btn btn-gold" style="width:100%; font-size:0.7rem;" onclick="alert('📥 TÉLÉCHARGEMENT SIMULÉ\\n\\nContenu de la fiche :\\n${f.content}')">Télécharger PDF</button>
            </div>
        `).join('');
    }

    function addFichePrompt() {
        const t = prompt("Titre de la fiche :");
        const c = prompt("Contenu résumé :");
        if(t && c) { db.fiches.push({id: Date.now(), title: t, content: c}); save(); renderFiches(); }
    }

    // --- CALENDRIER & RDV ---
    let selectedDay = null;
    function renderCalendar() {
        const cal = document.getElementById('calendar'); cal.innerHTML = '';
        for(let i=1; i<=31; i++) {
            const isBlocked = db.blockedDays.includes(i);
            const div = document.createElement('div');
            div.className = `cal-day ${isBlocked ? 'blocked' : ''}`;
            div.innerText = i;
            div.onclick = () => {
                if(document.body.classList.contains('role-admin')) {
                    if(isBlocked) db.blockedDays = db.blockedDays.filter(d => d !== i);
                    else db.blockedDays.push(i);
                    save(); renderCalendar();
                } else if(!isBlocked) {
                    selectedDay = i;
                    document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
                    div.classList.add('selected');
                    document.getElementById('rdv-box').style.display = 'block';
                    document.getElementById('rdv-text').innerText = "Session de mentorat prévue le " + i + " Mars 2026.";
                }
            };
            cal.appendChild(div);
        }
    }

    function confirmBooking() {
        alert("Demande de rendez-vous envoyée pour le " + selectedDay + " Mars. L'admin recevra une notification.");
        document.getElementById('next-rdv').innerText = selectedDay + " Mars 2026 à 14h00";
        showPage('dash');
    }

    // --- PITCHBOT (IA SIMULÉE) ---
    function askBot() {
        const input = document.getElementById('chat-input');
        const box = document.getElementById('chat-box');
        if(!input.value) return;
        
        box.innerHTML += `<div class="msg msg-user">${input.value}</div>`;
        const v = input.value.toLowerCase();
        let r = "Un mentor humain vous répondra très bientôt ! En attendant, consultez l'Académie.";
        
        if(v.includes("cv")) r = "Pour ton CV, privilégie un format épuré. J'ai une fiche dédiée dans l'onglet Académie !";
        if(v.includes("fiche") || v.includes("académie")) r = "Toutes les fiches de révision sont disponibles dans l'onglet Académie & Fiches.";
        if(v.includes("stage")) r = "Regarde l'onglet 'Stages & Alternances', j'y ai mis des liens vers Thales et le secteur Finance.";
        if(v.includes("bonjour") || v.includes("salut")) r = "Salut ! Je suis PitchBot. Prêt à décrocher ton futur job ?";

        setTimeout(() => {
            box.innerHTML += `<div class="msg msg-bot">${r}</div>`;
            box.scrollTop = box.scrollHeight;
        }, 600);
        input.value = '';
    }

    // --- LÉGAL ---
    function openLegal(type) {
        const content = {
            mentions: "<h2>Mentions Légales</h2><p><b>Propriétaire :</b> Léo Leszczynski (Pitchfield).<br><b>Hébergement :</b> LocalStorage Simulation.<br><b>Siège :</b> La Ferté-Saint-Aubin, France.</p>",
            cgu: "<h2>CGU & Confidentialité</h2><p><b>Politique :</b> Vos données sont stockées localement sur votre appareil. Aucune donnée n'est envoyée à un serveur externe.<br><br><b>CGU :</b> L'utilisation de Pitchfield implique le respect de la charte de bienveillance.</p>"
        };
        document.getElementById('legal-body').innerHTML = content[type];
        document.getElementById('modal-legal').style.display = 'flex';
    }
    function closeLegal() { document.getElementById('modal-legal').style.display = 'none'; }

    // LANCEMENT INITIAL
    showPage('dash');
</script>
</body>
</html>
