// ── CALENDAR ─────────────────────────────────────────────────
var calYear=2026, calMonth=2; // 0-indexed, 2=March
var RDV_EVENTS=[6,12,19,24,31];
var FREE_SLOTS=[23,26,27];
function buildCalendar(){
  var cal=document.getElementById('cal-days');
  if(!cal) return;
  var firstDay = new Date(calYear, calMonth, 1).getDay();
  firstDay = firstDay===0 ? 6 : firstDay-1; // Mon=0
  var daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  var today = new Date();
  var isCurrentMonth = (today.getFullYear()===calYear && today.getMonth()===calMonth);
  var todayDate = today.getDate();

  // Update title
  var months=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  var titleEl = document.querySelector('.cal-title');
  if(titleEl) titleEl.textContent = months[calMonth] + ' ' + calYear;

  cal.innerHTML='';
  // Empty cells before
  for(var i=0;i<firstDay;i++){
    var blank=document.createElement('div');
    blank.className='cal-day other-month';
    cal.appendChild(blank);
  }
  for(var d=1;d<=daysInMonth;d++){
    var div=document.createElement('div');
    div.className='cal-day';
    div.textContent=d;
    var tooltip='';
    if(isCurrentMonth && d===todayDate) { div.classList.add('today'); }
    if(RDV_EVENTS.includes(d)){ div.classList.add('has-event'); tooltip='RDV planifié'; }
    if(FREE_SLOTS.includes(d)){
      div.style.background='rgba(30,126,52,0.12)';
      div.style.color='var(--green)';
      div.style.fontWeight='700';
      div.style.borderRadius='8px';
      div.style.outline='2px solid rgba(30,126,52,0.4)';
      div.title='Créneau libre - Cliquez pour réserver';
    }
    if(tooltip) div.title=tooltip;
    div.onclick=(function(day){ return function(){
      document.querySelectorAll('.cal-day.selected').forEach(el=>el.classList.remove('selected'));
      this.classList.add('selected');
      if(RDV_EVENTS.includes(day)){
        showRdvInfo(day);
      } else if(FREE_SLOTS.includes(day)){
        openBooking(day);
      }
    };})(d);
    cal.appendChild(div);
  }
}
function changeMonth(dir){
  calMonth += dir;
  if(calMonth>11){calMonth=0;calYear++;}
  if(calMonth<0){calMonth=11;calYear--;}
  buildCalendar();
}

