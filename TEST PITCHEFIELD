var months=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
var rdvDB = []; // stockage des RDV créés
var currentRdvDay = null; // jour en cours de création/consultation

function openBooking(day){
  currentRdvDay = day;
  document.getElementById('booking-label').textContent = day+' '+months[calMonth]+' '+calYear;
  mOpen('booking-modal');
}

function confirmBooking(){
  var day = currentRdvDay;
  var label = document.getElementById('booking-label').textContent;
  // Récupérer les valeurs du formulaire
  var selects = document.querySelectorAll('#booking-modal select');
  var type   = selects[0] ? selects[0].value : 'Session';
  var heure  = selects[1] ? selects[1].value : '10h00';
  var format = selects[2] ? selects[2].value : 'Zoom';
  var noteEl = document.querySelector('#booking-modal textarea');
  var note   = noteEl ? noteEl.value.trim() : '';
  mClose('booking-modal');
  // Enregistrer le RDV
  rdvDB.push({ day:day, month:calMonth, year:calYear, label:label, type:type, heure:heure, format:format, note:note });
  if(!RDV_EVENTS.includes(day)) RDV_EVENTS.push(day);
  var fi = FREE_SLOTS.indexOf(day); if(fi>-1) FREE_SLOTS.splice(fi,1);
  buildCalendar();
  renderRdvLists();
  showRdvInfo(day);
}

function showRdvInfo(day){
  // Trouver le RDV dans rdvDB
  var rdv = rdvDB.find(function(r){ return r.day===day && r.month===calMonth && r.year===calYear; });
  var html = '';
  if(rdv){
    html += '<div style="display:grid;grid-template-columns:auto 1fr;gap:6px 14px;align-items:center;">';
    html += '<span style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Date</span><span style="font-size:14px;font-weight:500;color:var(--navy)">'+rdv.label+'</span>';
    html += '<span style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Heure</span><span style="font-size:14px;color:var(--navy)">'+rdv.heure+'</span>';
    html += '<span style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Type</span><span style="font-size:14px;color:var(--navy)">'+rdv.type+'</span>';
    html += '<span style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Format</span><span style="font-size:14px;color:var(--gold);font-weight:500;">'+rdv.format+'</span>';
    if(rdv.note){ html += '<span style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;">Note</span><span style="font-size:13px;color:var(--text-mid);font-style:italic;">'+rdv.note+'</span>'; }
    html += '</div>';
  } else {
    html = '<div style="font-size:14px;color:var(--text-mid)">RDV planifié le '+day+' '+months[calMonth]+'</div>';
  }
  document.getElementById('rdvinfo-content').innerHTML = html;
  // Configurer le bouton supprimer
  var delBtn = document.getElementById('rdv-delete-btn');
  if(delBtn){
    delBtn.onclick = function(){
      if(confirm('Supprimer ce rendez-vous ?')){
        // Supprimer de rdvDB
        rdvDB = rdvDB.filter(function(r){ return !(r.day===day && r.month===calMonth && r.year===calYear); });
        // Remettre le créneau en libre
        var ri = RDV_EVENTS.indexOf(day); if(ri>-1) RDV_EVENTS.splice(ri,1);
        if(!FREE_SLOTS.includes(day)) FREE_SLOTS.push(day);
        buildCalendar();
        renderRdvLists();
        mClose('rdvinfo-modal');
      }
    };
  }
  mOpen('rdvinfo-modal');
}

function renderRdvLists(){
  // Trier par date
  var sorted = rdvDB.slice().sort(function(a,b){ return (a.year*10000+a.month*100+a.day)-(b.year*10000+b.month*100+b.day); });
  var makeItem = function(rdv, canDelete){
    var html = '<div class="rdv-item" style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">';
    html += '<div>';
    html += '<div class="rdv-name">'+rdv.type+'</div>';
    html += '<div class="rdv-date">'+rdv.label+' · '+rdv.heure+'</div>';
    html += '<div class="rdv-type">'+rdv.format+'</div>';
    if(rdv.note) html += '<div style="font-size:11px;color:var(--text-light);margin-top:4px;font-style:italic;">'+rdv.note+'</div>';
    html += '</div>';
    if(canDelete){
      html += '<button onclick="deleteRdv('+rdv.day+','+rdv.month+','+rdv.year+')" title="Supprimer" style="background:none;border:none;cursor:pointer;color:#E24B4A;font-size:18px;padding:2px 4px;line-height:1;flex-shrink:0;">×</button>';
    }
    html += '</div>';
    return html;
  };
  // Dashboard
  var dashList = document.getElementById('dash-rdv-list');
  if(dashList){
    if(sorted.length===0){
      dashList.innerHTML='<div style="font-size:13px;color:var(--text-light);text-align:center;padding:16px;">Aucun RDV planifié.</div>';
    } else {
      dashList.innerHTML = sorted.slice(0,3).map(function(r){ return makeItem(r,false); }).join('');
    }
  }
  // Page RDV
  var rdvList = document.getElementById('rdv-list-side');
  if(rdvList){
    if(sorted.length===0){
      rdvList.innerHTML='<div style="font-size:13px;color:var(--text-light);text-align:center;padding:12px;">Aucun RDV planifié.</div>';
    } else {
      rdvList.innerHTML = sorted.map(function(r){ return makeItem(r,true); }).join('');
    }
  }
}

function deleteRdv(day, month, year){
  if(!confirm('Supprimer ce rendez-vous ?')) return;
  rdvDB = rdvDB.filter(function(r){ return !(r.day===day && r.month===month && r.year===year); });
  var ri = RDV_EVENTS.indexOf(day); if(ri>-1) RDV_EVENTS.splice(ri,1);
  if(month===calMonth && year===calYear && !FREE_SLOTS.includes(day)) FREE_SLOTS.push(day);
  buildCalendar();
  renderRdvLists();
}

