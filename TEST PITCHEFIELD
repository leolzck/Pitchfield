// ── ACADEMY LOGIC ──
var currentAcademyCat = 'all';

function renderAcademy(){
    // Rendu des modules pour les étudiants
    var grid = document.getElementById('courses-grid');
    grid.innerHTML = '';
    
    COURSE_DATA.forEach(course => {
        if(currentAcademyCat !== 'all' && course.cat !== currentAcademyCat) return;
        
        var vids = videoDB[course.id] || [];
        var card = document.createElement('div');
        card.className = 'course-card';
        card.innerHTML = `
            <div class="course-thumb">${course.icon}</div>
            <div class="course-body">
                <div class="course-title">${course.title}</div>
                <p style="font-size:12px; color:var(--text-mid);">${course.desc}</p>
                <div class="video-player-section ${vids.length > 0 ? 'has-videos' : ''}">
                    <div style="font-size:10px; font-weight:700; margin-bottom:8px; text-transform:uppercase;">${vids.length} Vidéos disponibles</div>
                    <div class="pills-container">
                        ${vids.map((v, i) => `<span class="video-pill" onclick="playVideo('${course.id}', ${i}, this)">► ${v.title}</span>`).join('')}
                    </div>
                    <div class="video-embed-area" id="embed-${course.id}"></div>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });

    // Rendu de la liste admin
    var adminList = document.getElementById('admin-module-list');
    if(adminList){
        adminList.innerHTML = '';
        COURSE_DATA.forEach(course => {
            var count = (videoDB[course.id] || []).length;
            var item = document.createElement('div');
            item.className = 'admin-module-item';
            item.innerHTML = `
                <span style="color:white; flex:1; font-size:13px;">${course.title}</span>
                <span style="color:var(--gold); font-size:11px;">${count} vidéos</span>
                <button class="admin-add-btn" onclick="openAddVideo('${course.id}', '${course.title}')">+ Vidéo</button>
            `;
            adminList.appendChild(item);
        });
    }
}

function setAcademyCat(cat, el){
    currentAcademyCat = cat;
    document.querySelectorAll('.academy-cat').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    renderAcademy();
}

function filterAcademy(){
    var q = document.getElementById('academy-search-input').value.toLowerCase();
    document.querySelectorAll('.course-card').forEach(card => {
        var title = card.querySelector('.course-title').innerText.toLowerCase();
        card.style.display = title.includes(q) ? 'flex' : 'none';
    });
}

// ── VIDÉO LOGIC ──
var activeCourseId = '';

function openAddVideo(id, title){
    activeCourseId = id;
    document.getElementById('vid-course-label').innerText = "Module : " + title;
    mOpen('video-modal');
}

function saveVideo(){
    var t = document.getElementById('vid-title').value;
    var u = document.getElementById('vid-url').value;
    var d = document.getElementById('vid-dur').value;
    
    if(!t || !u) return alert("Titre et URL requis");
    
    if(!videoDB[activeCourseId]) videoDB[activeCourseId] = [];
    videoDB[activeCourseId].push({ title: t, url: u, dur: d });
    
    localStorage.setItem('pitchfield_videos', JSON.stringify(videoDB));
    mClose('video-modal');
    renderAcademy();
}

function playVideo(courseId, index, el){
    var video = videoDB[courseId][index];
    var area = document.getElementById('embed-'+courseId);
    
    // Toggle
    if(area.style.display === 'block' && area.dataset.idx == index){
        area.style.display = 'none';
        return;
    }

    var id = "";
    if(video.url.includes('youtube.com') || video.url.includes('youtu.be')){
        id = video.url.split('v=')[1] || video.url.split('/').pop();
        area.innerHTML = `<iframe width="100%" height="200" src="https://www.youtube.com/embed/${id}?autoplay=1" frameborder="0" allowfullscreen></iframe>`;
    } else {
        area.innerHTML = `<div style="padding:20px; color:white; font-size:12px;"><a href="${video.url}" target="_blank" style="color:var(--gold);">Cliquez pour ouvrir la vidéo externe ↗</a></div>`;
    }
    
    area.style.display = 'block';
    area.dataset.idx = index;
}

// ── UTILS ──
function mOpen(id){ document.getElementById(id).style.display = 'flex'; }
function mClose(id){ document.getElementById(id).style.display = 'none'; }

function toggleMobileMenu(){
    var m = document.getElementById('mobile-menu');
    m.style.display = (m.style.display === 'block') ? 'none' : 'block';
}

// ── CALENDRIER (BASIC) ──
function buildCalendar(){
    var cal = document.getElementById('cal-days');
    if(!cal) return;
    cal.innerHTML = '';
    for(var i=1; i<=31; i++){
        var d = document.createElement('div');
        d.className = 'cal-day';
        d.innerText = i;
        if(i == 19) d.classList.add('today');
        cal.appendChild(d);
    }
}

window.onload = function(){
    buildCalendar();
};

