<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pitchfield — Là où ton futur commence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
/* --- TES VARIABLES ET STYLES EXISTANTS --- */
:root{
  --navy:#0D1B2E;--navy-mid:#1A3A5C;--navy-light:#243F60;
  --gold:#C9A84C;--gold-light:#E8C96A;--gold-pale:#FFF8E7;
  --cream:#F9F6F0;--white:#FFFFFF;
  --text-dark:#0D1B2E;--text-mid:#4A5568;--text-light:#8898A8;
  --border:rgba(13,27,46,0.1);--green:#1E7E34;--green-light:#D4EDDA;
  --red:#E24B4A;--sidebar-w:240px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}

/* NAVIGATION */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(13,27,46,0.97);backdrop-filter:blur(12px);
  height:64px;display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;border-bottom:1px solid rgba(201,168,76,0.2);
}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--gold);cursor:pointer;}
.nav-logo span{color:var(--white);}
.nav-links{display:flex;gap:32px;align-items:center;}
.nav-links a{color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;cursor:pointer;transition:color .2s;}
.nav-links a:hover{color:var(--white);}

/* GESTION DES PAGES */
.page { display: none; min-height: 100vh; padding-top: 64px; }
.page.active { display: block; }
#page-app { padding-top: 64px; } /* L'app commence après la nav */

/* SIDEBAR LAYOUT */
.app-layout{display:flex;min-height:calc(100vh - 64px);}
.sidebar{
  width:var(--sidebar-w);background:var(--navy);flex-shrink:0;position:fixed;
  top:64px;bottom:0;left:0;overflow-y:auto;padding:24px 0;
  border-right:1px solid rgba(255,255,255,0.06);
}
.main-content{margin-left:var(--sidebar-w);flex:1;padding:32px 36px;background:var(--cream);min-height:calc(100vh - 64px);}

/* --- STYLES DES COMPOSANTS (REPRIS DE TON CODE) --- */
.sidebar-user{padding:0 20px 24px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:16px;}
.sidebar-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--navy);margin-bottom:10px;}
.sidebar-name{font-size:14px;font-weight:500;color:var(--white);}
.sidebar-role{font-size:12px;color:rgba(255,255,255,0.45);margin-top:2px;}
.sidebar-nav{list-style:none;padding:0 8px;}
.sidebar-nav li a{
  display:flex;align-items:center;gap:12px;padding:10px 12px;
  border-radius:10px;color:rgba(255,255,255,0.6);text-decoration:none;
  font-size:13.5px;cursor:pointer;transition:all .2s;
}
.sidebar-nav li a:hover, .sidebar-nav li a.active{background:rgba(255,255,255,0.07);color:var(--gold);}
.sidebar-nav li a .icon{width:18px;height:18px;opacity:0.8;}
.sidebar-section{font-size:10px;font-weight:500;color:rgba(255,255,255,0.25);letter-spacing:1px;text-transform:uppercase;padding:16px 20px 6px;}

/* DASHBOARD SPECIFICS */
.dash-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.kpi-card{background:var(--white);border-radius:16px;padding:20px;border:1px solid var(--border);}
.kpi-value{font-family:'Syne',sans-serif;font-size:24px;font-weight:700;color:var(--navy);}

/* --- AJOUTE ICI LE RESTE DE TES STYLES (HERO, FEATURES, ACADEMY, ETC.) --- */
/* (J'ai raccourci pour la lisibilité, mais garde bien tout ton CSS original ici) */
/* ... */
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-logo" onclick="showPage('home')">Pitch<span>field</span></div>
  <div class="nav-links">
    <a onclick="showPage('home')">Accueil</a>
    <a onclick="showPage('offres')">Offres</a>
    <a onclick="showPage('app')">Mon Espace</a>
    <a onclick="showPage('contact')">Contact</a>
  </div>
  <div class="nav-right">
    <button class="nav-cta" onclick="showPage('login')">Connexion</button>
  </div>
</nav>

<div id="page-home" class="page active">
    <div style="padding: 100px; text-align: center;">
        <h1>Le terrain où tu apprends à convaincre.</h1>
        <button class="btn-primary" onclick="showPage('login')">Démarrer</button>
    </div>
</div>

<div id="page-offres" class="page">
    <div style="padding: 50px;">
        <h2>Nos Offres</h2>
        </div>
</div>

<div id="page-login" class="page">
    <div style="padding: 50px; text-align: center;">
        <h2>Connexion</h2>
        <button class="form-btn" onclick="showPage('app')">Simuler Connexion Étudiant</button>
    </div>
</div>

<div id="page-app" class="page">
  <div class="app-layout">
    <aside class="sidebar">
      <div class="sidebar-user">
        <div class="sidebar-avatar">LL</div>
        <div class="sidebar-name">Léo Leszczynski</div>
        <div class="sidebar-role">Étudiant</div>
      </div>
      
      <div class="sidebar-section">Principal</div>
      <ul class="sidebar-nav">
        <li><a onclick="showAppSubPage('dashboard')" id="side-dashboard" class="active">Dashboard</a></li>
        <li><a onclick="showAppSubPage('recherche')" id="side-recherche">Recherche</a></li>
        <li><a onclick="showAppSubPage('messages')" id="side-messages">Messages</a></li>
        <li><a onclick="showAppSubPage('rdv')" id="side-rdv">Rendez-vous</a></li>
      </ul>

      <div class="sidebar-section">Formation & Emploi</div>
      <ul class="sidebar-nav">
        <li><a onclick="showAppSubPage('academy')" id="side-academy">Académie</a></li>
        <li><a onclick="showAppSubPage('stage')" id="side-stage">Stage & Alternance</a></li>
      </ul>

      <div class="sidebar-section">Compte</div>
      <ul class="sidebar-nav">
        <li><a onclick="showAppSubPage('profil')" id="side-profil">Mon Profil</a></li>
        <li><a onclick="showPage('home')">Déconnexion</a></li>
      </ul>
    </aside>

    <main class="main-content">
      <div id="app-dashboard" class="app-sub-page">
        <h1>Mon Dashboard</h1>
        <div class="dash-kpis">
            <div class="kpi-card"><div class="kpi-value">12</div><div>Sessions</div></div>
            <div class="kpi-card"><div class="kpi-value">4/10</div><div>Modules</div></div>
        </div>
      </div>

      <div id="app-recherche" class="app-sub-page" style="display:none;">
        <h1>Explorer les domaines</h1>
        </div>

      <div id="app-academy" class="app-sub-page" style="display:none;">
        <h1>Académie Pitchfield</h1>
        </div>

      <div id="app-profil" class="app-sub-page" style="display:none;">
        <h1>Mon Profil</h1>
        </div>
      
      <div id="app-messages" class="app-sub-page" style="display:none;">
        <h1>Mes Messages</h1>
      </div>

      <div id="app-rdv" class="app-sub-page" style="display:none;">
        <h1>Mes Rendez-vous</h1>
      </div>

      <div id="app-stage" class="app-sub-page" style="display:none;">
        <h1>Offres de stages</h1>
      </div>

    </main>
  </div>
</div>

<script>
// --- FONCTION DE NAVIGATION PRINCIPALE ---
function showPage(pageId) {
    // Cache toutes les pages
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    
    // Affiche la page demandée
    const target = document.getElementById('page-' + pageId);
    if(target) target.classList.add('active');
    
    // Si on va sur l'app, on affiche le dashboard par défaut
    if(pageId === 'app') {
        showAppSubPage('dashboard');
    }
    window.scrollTo(0,0);
}

// --- FONCTION DE NAVIGATION INTERNE A L'APP (SIDEBAR) ---
function showAppSubPage(subPageId) {
    // Cache toutes les sous-sections de l'app
    document.querySelectorAll('.app-sub-page').forEach(p => p.style.display = 'none');
    
    // Affiche la sous-section
    const target = document.getElementById('app-' + subPageId);
    if(target) target.style.display = 'block';
    
    // Gère l'état actif dans la sidebar
    document.querySelectorAll('.sidebar-nav li a').forEach(a => a.classList.remove('active'));
    const sideLink = document.getElementById('side-' + subPageId);
    if(sideLink) sideLink.classList.add('active');
}

// Initialisation au chargement
document.addEventListener('DOMContentLoaded', () => {
    // Tu peux ajouter tes fonctions d'initialisation ici (ex: buildCalendar())
});
</script>

</body>
</html>
