    </main>
  </div>
</div>

<script>
/* ── LOGIQUE DE NAVIGATION ── */

// 1. Navigation entre les grandes pages (Home, Login, App)
function showPage(pageName) {
  // Masquer toutes les pages
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  
  // Afficher la page ciblée
  const target = document.getElementById('page-' + pageName);
  if(target) target.classList.add('active');

  // Si on entre dans l'app, on force l'affichage du dashboard
  if(pageName === 'app') {
    showAppSub('dashboard');
  }
  
  window.scrollTo(0,0);
}

// 2. Navigation à l'intérieur de l'App (via la Sidebar)
function showAppSub(subName) {
  // Masquer toutes les sous-sections de l'App
  document.querySelectorAll('.sub-section').forEach(s => s.style.display = 'none');
  
  // Afficher la sous-section ciblée
  const target = document.getElementById('app-' + subName);
  if(target) target.style.display = 'block';

  // Mettre à jour l'état actif dans la sidebar
  document.querySelectorAll('.sidebar-nav li a').forEach(a => a.classList.remove('active'));
  const navLink = document.getElementById('nav-' + subName);
  if(navLink) navLink.classList.add('active');
}

/* ── REPRISE DE TES SCRIPTS ORIGINAUX (SIMPLIFIÉ POUR L'EXEMPLE) ── */
// Tu peux remettre ici tes fonctions complexes (buildCalendar, etc.) sans problème.

</script>
