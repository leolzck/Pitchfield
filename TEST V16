      </div>

      <div id="app-academy" class="sub-section" style="display:none;">
        <h1>Académie Pitchfield</h1>
        <div class="courses-grid" style="margin-top:20px;">
          <div class="course-card">
            <div class="course-thumb" style="background:#0D1B2E;">🎯</div>
            <div style="padding:15px;"><h4>Préparer son entretien</h4><p>6 leçons · Tous niveaux</p></div>
          </div>
          <div class="course-card">
            <div class="course-thumb" style="background:#1E7E34;">📄</div>
            <div style="padding:15px;"><h4>CV ATS & IA</h4><p>4 leçons · Débutant</p></div>
          </div>
