// ── DOMAINES ─────────────────────────────────────────────────
function filterDomains(cat,el){
  document.querySelectorAll('.filter-tag').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.domain-card').forEach(c=>{
    c.style.display=(cat==='all'||c.dataset.cat===cat)?'block':'none';
  });
}
function searchDomains(){
  var q = document.getElementById('search-input').value.toLowerCase();
  document.querySelectorAll('.domain-card').forEach(c=>{
    var txt = c.textContent.toLowerCase();
    c.style.display = (!q || txt.includes(q)) ? 'block' : 'none';
  });
}

// ── ACADEMY FILTERS ──────────────────────────────────────────
var currentAcademyCat = 'all';
function setAcademyCat(cat,el){
  currentAcademyCat = cat;
  document.querySelectorAll('.academy-cat').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  filterAcademy();
}
function filterAcademy(){
  var q     = (document.getElementById('academy-search-input').value||'').toLowerCase();
  var level = document.getElementById('level-filter').value;
  var cards = document.querySelectorAll('.course-card');
  var visible = 0;
  cards.forEach(c=>{
    var matchCat   = currentAcademyCat==='all' || c.dataset.cat===currentAcademyCat;
    var matchLevel = !level || c.dataset.level===level;
    var matchQ     = !q || c.dataset.title.toLowerCase().includes(q) || c.textContent.toLowerCase().includes(q);
    var show = matchCat && matchLevel && matchQ;
    c.style.display = show ? 'flex' : 'none';
    if(show) visible++;
  });
  document.getElementById('academy-no-result').style.display = visible===0 ? 'block' : 'none';
}

// ── CHAT ─────────────────────────────────────────────────────
function sendMsg(){
  var input = document.getElementById('chat-input');
  var txt = input.value.trim();
  if(!txt) return;
  var msgs = document.querySelector('.chat-messages');
  var div = document.createElement('div');
  div.className='msg msg-out';
  div.innerHTML='<div class="msg-bubble">'+txt+'</div><div class="msg-time">maintenant</div>';
  msgs.appendChild(div);
  input.value='';
  msgs.scrollTop=msgs.scrollHeight;
  setTimeout(()=>{
    var r=document.createElement('div');
    r.className='msg msg-in';
    r.innerHTML='<div class="msg-bubble">Merci pour votre message ! Je vous réponds très prochainement.</div><div class="msg-time">maintenant</div>';
    msgs.appendChild(r);
    msgs.scrollTop=msgs.scrollHeight;
  },1200);
}

// ── CALENDAR ─────────────────────────────────────────────────
var calYear=2026, calMonth=2; // 0-indexed, 2=March
var RDV_EVENTS=[6,12,19,24,31];
var FREE_SLOTS=[23,26,27];
function buildCalendar(){
  var cal=document.getElementById('cal-days');
  if(!cal) return;
  var firstDay = new Date(calYear, calMonth, 1).getDay();
  firstDay = firstDay===0 ? 6 : firstDay-1; // Mon=0
  var daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  var today = new Date();
  var isCurrentMonth = (today.getFullYear()===calYear && today.getMonth()===calMonth);
  var todayDate = today.getDate();

  // Update title
  var months=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  var titleEl = document.querySelector('.cal-title');
  if(titleEl) titleEl.textContent = months[calMonth] + ' ' + calYear;

  cal.innerHTML='';
  // Empty cells before
  for(var i=0;i<firstDay;i++){
    var blank=document.createElement('div');
    blank.className='cal-day other-month';
    cal.appendChild(blank);
  }
  for(var d=1;d<=daysInMonth;d++){
    var div=document.createElement('div');
    div.className='cal-day';
    div.textContent=d;
    var tooltip='';
    if(isCurrentMonth && d===todayDate) { div.classList.add('today'); }
    if(RDV_EVENTS.includes(d)){ div.classList.add('has-event'); tooltip='RDV planifié'; }
    if(FREE_SLOTS.includes(d)){
      div.style.background='rgba(30,126,52,0.12)';
      div.style.color='var(--green)';
      div.style.fontWeight='700';
      div.style.borderRadius='8px';
      div.style.outline='2px solid rgba(30,126,52,0.4)';
      div.title='Créneau libre - Cliquez pour réserver';
    }
    if(tooltip) div.title=tooltip;
    div.onclick=(function(day){ return function(){
      document.querySelectorAll('.cal-day.selected').forEach(el=>el.classList.remove('selected'));
      this.classList.add('selected');
      if(RDV_EVENTS.includes(day)){
        showRdvInfo(day);
      } else if(FREE_SLOTS.includes(day)){
        openBooking(day);
      }
    };})(d);
    cal.appendChild(div);
  }
}
function changeMonth(dir){
  calMonth += dir;
  if(calMonth>11){calMonth=0;calYear++;}
  if(calMonth<0){calMonth=11;calYear--;}
  buildCalendar();
}

// ── INIT ─────────────────────────────────────────────────────
buildCalendar();

// ── CONTACT ──────────────────────────────────────────────────
function submitContact(){
  var nom=document.getElementById('c-nom').value.trim();
  var email=document.getElementById('c-email').value.trim();
  var dest=document.getElementById('c-dest').value;
