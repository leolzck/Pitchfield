function p14SwitchConv(id){
  P14_ACTIVE_CONV=id;var c=P14_CONVS[id];if(!c)return;
  var av=document.getElementById('p14-chat-av'),na=document.getElementById('p14-chat-name'),su=document.getElementById('p14-chat-sub');
  if(av){av.textContent=c.av;av.style.background=c.bg;av.style.color=c.co;}
  if(na)na.textContent=c.na;if(su)su.textContent=c.su;
  document.querySelectorAll('.conv-item').forEach(function(el,i){el.classList.toggle('active',i===id-1);});
  var area=document.querySelector('.chat-messages');if(!area)return;
  area.innerHTML=c.ms.map(function(m){return '<div class="msg msg-'+(m.o?'out':'in')+'"><div class="msg-bubble">'+m.t+'</div><div class="msg-time">'+m.ti+'</div></div>';}).join('');
  area.scrollTop=area.scrollHeight;
}

function p14StartMsg(proId){
  var p=P14_PROS.find(function(x){return x.id===proId;});if(!p)return;
  p14Mc('new-conv');p14Mc('view-pro');
  var nid=Object.keys(P14_CONVS).length+1;while(P14_CONVS[nid])nid++;
  P14_CONVS[nid]={na:p.pr+' '+p.no,su:p.ti,av:p.in,bg:p.bg,co:p.co,ms:[{o:false,t:'Bonjour ! Je suis '+p.pr+'. Comment puis-je vous aider ?',ti:'maintenant'}]};
  var cl=document.querySelector('.messages-list');
  if(cl){
    var ni=document.createElement('div');ni.className='conv-item';ni.setAttribute('onclick','p14SwitchConv('+nid+')');ni.style.cursor='pointer';
    ni.innerHTML='<div class="conv-avatar" style="background:'+p.bg+';color:'+p.co+'">'+p.in+'</div>'+
      '<div class="conv-body"><div class="conv-name">'+p.pr+' '+p.no+'</div><div class="conv-preview">Nouvelle conv.</div></div>'+
      '<div class="conv-meta"><div class="conv-time">maint.</div></div>';
    var btn=cl.querySelector('button');if(btn)btn.after(ni);else cl.appendChild(ni);
