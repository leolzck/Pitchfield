function p14UpdateCard(course){
  document.querySelectorAll('.course-card').forEach(function(card){
    var t=card.dataset.title||card.querySelector('.course-title').textContent;if(t!==course)return;
    var fiches=P14_FICHES[t]||[];if(!fiches.length)return;
    var sec=card.querySelector('.p14-fiche-sec');
    if(!sec){sec=document.createElement('div');sec.className='p14-fiche-sec';sec.style.cssText='margin-top:8px;border-top:1px solid var(--border);padding-top:8px;';card.querySelector('.course-body').appendChild(sec);}
    sec.innerHTML='<div style="font-size:10px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;">'+fiches.length+' fiche'+(fiches.length>1?'s':'')+'</div>'+
      fiches.map(function(f,i){return '<span class="fiche-pill" data-c="'+encodeURIComponent(course)+'" data-i="'+i+'" onclick="p14ReadFiche(this)">&#128196; '+f.ti+'</span>';}).join('');
  });
}
function p14ReadFiche(el){
  var course=decodeURIComponent(el.getAttribute('data-c')),idx=parseInt(el.getAttribute('data-i'));
  var f=(P14_FICHES[course]||[])[idx];if(!f)return;
  var header='<div style="font-family:Syne,sans-serif;font-size:17px;font-weight:700;color:var(--navy);margin-bottom:5px;">'+f.ti+'</div>'+
    '<div style="font-size:11px;color:var(--text-light);margin-bottom:13px;">'+course+' · '+f.lv+'</div>';
  var body='';
  if(f.fileData){
    if(f.fileData.type==='image')body='<img src="'+f.fileData.url+'" style="width:100%;border-radius:10px;">';
    else body='<div style="text-align:center;padding:18px;"><a href="'+f.fileData.url+'" download="'+f.fileData.name+'" style="background:var(--navy);color:white;padding:11px 22px;border-radius:50px;text-decoration:none;font-size:14px;font-weight:500;">&#11015; Télécharger</a></div>';
  } else {
