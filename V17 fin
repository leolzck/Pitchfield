// ── ROUTING ──────────────────────────────────────────────────
var APP_PAGES = ['dashboard','recherche','favoris','messages','rdv','academy','stage','profil','avis','admin-pros','admin-cal','pitchbot'];
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  closeMobileMenu();
  if(APP_PAGES.indexOf(name) !== -1){
    document.getElementById('page-app').classList.add('active');
    showAppPage(name);
  } else {
    var pg = document.getElementById('page-'+name);
    if(pg) pg.classList.add('active');
  }
  window.scrollTo(0,0);
}
function showApp(){ showPage('dashboard'); }
function showAppPage(name){
  document.querySelectorAll('[id^="app-"]').forEach(p=>p.style.display='none');
  var el = document.getElementById('app-'+name);
  if(el) el.style.display='block';
  document.querySelectorAll('.sidebar-nav li a').forEach(a=>a.classList.remove('active'));
  var nav = document.getElementById('nav-'+name);
  if(nav) nav.classList.add('active');
}

// ── TABS LOGIN ────────────────────────────────────────────────
function switchTab(tab){
