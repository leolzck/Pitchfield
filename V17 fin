function p14SaveFiche(){
  var ti=g('mf-ti');var course=document.getElementById('mo-fiche-course').textContent.replace('Module : ','');
  if(!ti){alert('Titre requis.');return;}
  var fs=document.getElementById('mf-file-sec');var isFile=fs&&fs.style.display!=='none';
  var co_txt=g('mf-co');var fileData=null;
  if(isFile){
    var inp=document.getElementById('mf-file-inp');
    if(inp&&inp._fileUrl){fileData={url:inp._fileUrl,type:inp._fileType,name:inp._fileName};co_txt=inp._fileName;}
    else if(!co_txt){alert('Sélectionnez un fichier ou saisissez du contenu.');return;}
  } else if(!co_txt){alert('Contenu requis.');return;}
  if(!P14_FICHES[course])P14_FICHES[course]=[];
