<script>
/* ════ PITCHFIELD V14 — Toutes nouvelles fonctionnalités ════
   Préfixe p14_ — aucun conflit avec V9                       */

/* ── Modales ─────────────────────────────────────────────── */
function p14Mo(id){var el=document.getElementById('p14-mo-'+id);if(el){el.style.display='flex';document.body.style.overflow='hidden';}}
function p14Mc(id){var el=document.getElementById('p14-mo-'+id);if(el){el.style.display='none';document.body.style.overflow='';}}
document.addEventListener('keydown',function(e){if(e.key==='Escape')['add-pro','view-pro','add-job','add-fiche','read-fiche','new-conv'].forEach(p14Mc);});

/* ── Email simulation ─────────────────────────────────────── */
function p14Toast(to,body){
  var t=document.getElementById('email-toast');
  var toEl=document.getElementById('email-toast-to');
  var bEl=document.getElementById('email-toast-body');
  if(!t)return;
  if(toEl)toEl.textContent='contact@pitchfield.fr → '+to;
  if(bEl)bEl.innerHTML=body;
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},6000);
}

/* ── Inscription réelle ───────────────────────────────────── */
function p14Register(){
  var prenom=(document.getElementById('rg-prenom')||{}).value||'';
  var nom=(document.getElementById('rg-nom')||{}).value||'';
  var email=((document.getElementById('rg-email')||{}).value||'').trim().toLowerCase();
  var pwd=(document.getElementById('rg-pwd')||{}).value||'';
  var level=(document.getElementById('rg-level')||{}).value||'';
  var school=(document.getElementById('rg-school')||{}).value||'';
  var sector=(document.getElementById('rg-sector')||{}).value||'';
  var obj=(document.getElementById('rg-obj')||{}).value||'';
  var bio=(document.getElementById('rg-bio')||{}).value||'';
  var errEl=document.getElementById('rg-err');
  prenom=prenom.trim();nom=nom.trim();
  function showErr(m){if(errEl){errEl.textContent=m;errEl.style.display='block';}else alert(m);}
  if(!prenom||!nom){showErr('Prénom et nom requis.');return;}
  if(!email||email.indexOf('@')<0){showErr('Email invalide.');return;}
  if(pwd.length<8){showErr('Mot de passe trop court (min. 8 caractères).');return;}
  if(USERS[email]){showErr('Un compte existe déjà avec cet email.');return;}
  var initials=(prenom[0]+(nom[0]||'')).toUpperCase();
  USERS[email]={pwd:pwd,role:'user',name:prenom+' '+nom,roleLabel:level||'Étudiant',initials:initials};
  P14_PROFILES[email]={prenom:prenom,nom:nom,school:school,level:level,sector:sector,objective:obj,bio:bio,langues:'',diplomes:'',linkedin:'',tel:'',city:'',handicap:'',dob:''};
  if(errEl)errEl.style.display='none';
  currentUser=USERS[email];
  applyRole();
  setTimeout(function(){
    p14Toast(email,'<strong>Bienvenue sur Pitchfield, '+prenom+' !</strong><br><br>Merci d\'avoir rejoint la plateforme. Ton compte est actif. Tu peux dès maintenant explorer les mentors, réserver ta première session gratuite et accéder à l\'Académie.<br><br>À bientôt,<br><strong>L\'équipe Pitchfield</strong>');
  },800);
  showApp();
  if(typeof showToast==='function')showToast('Bienvenue '+prenom+' ! 🎉');
}

