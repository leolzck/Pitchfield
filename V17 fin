function p14HandleFicheFile(input){
  var file=input.files[0];if(!file)return;
  var ok=document.getElementById('mf-file-ok');
  var ext=(file.name.split('.').pop()||'').toLowerCase();
  if(ext==='txt'){
    var r=new FileReader();r.onload=function(e){var co=document.getElementById('mf-co');if(co)co.value=e.target.result;p14FicheTab('txt');if(ok){ok.textContent='Contenu importé depuis '+file.name;ok.style.display='block';}};r.readAsText(file);
  } else {
    if(ok){ok.textContent='Fichier sélectionné : '+file.name;ok.style.display='block';}
    input._fileUrl=URL.createObjectURL(file);input._fileType=ext==='pdf'||ext==='doc'||ext==='docx'?'document':'image';input._fileName=file.name;
  }
