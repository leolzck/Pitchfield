function p14ChWeek(d){P14_WO+=d;p14BuildWeek();}
function p14BuildWeek(){
  var grid=document.getElementById('wg-grid');if(!grid)return;
  var b=new Date(2026,2,23);b.setDate(b.getDate()+P14_WO*7);
  var lbl=document.getElementById('wg-lbl');if(lbl)lbl.textContent='Semaine du '+b.toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
  var h='<div class="wg-h" style="background:var(--cream);color:var(--text-light);border-right:1px solid var(--border);"></div>';
  P14_WD.forEach(function(d){h+='<div class="wg-h">'+d+'</div>';});
  P14_WH.forEach(function(hr){
    h+='<div class="wg-t">'+hr+'</div>';
    P14_WD.forEach(function(d){
      var k=P14_WO+'_'+d+'_'+hr;var bl=!!P14_BL[k];
      var bk=typeof rdvDB!=='undefined'&&rdvDB.some(function(r){return r.heure&&r.heure.startsWith(hr.replace('h',''));});
      var cls=bl?'bl':bk?'bk':'av';
      h+='<div class="wg-c '+cls+'" data-k="'+k+'" onclick="p14TogSlot(this)" title="'+d+' '+hr+(bl?' — Bloqué':bk?' — RDV':' — Disponible')+'">'+(bl?'&#x2715;':bk?'RDV':'')+'</div>';
    });
  });
  grid.innerHTML=h;
