<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pitchfield — Là où ton futur commence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0D1B2E;--navy-mid:#1A3A5C;--navy-light:#243F60;
  --gold:#C9A84C;--gold-light:#E8C96A;--gold-pale:#FFF8E7;
  --cream:#F9F6F0;--white:#FFFFFF;
  --text-dark:#0D1B2E;--text-mid:#4A5568;--text-light:#8898A8;
  --border:rgba(13,27,46,0.1);--green:#1E7E34;--green-light:#D4EDDA;
  --red:#E24B4A;--sidebar-w:240px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}

/* ── RESPONSIVE UTILITIES ── */
@media(max-width:768px){
  .hide-mobile{display:none!important;}
  .nav-links{display:none!important;}
  .hero{padding:100px 24px 60px!important;flex-direction:column!important;}
  .hero-stats{position:static!important;transform:none!important;flex-direction:row!important;flex-wrap:wrap!important;gap:12px!important;margin-top:40px!important;width:100%!important;}
  .hero h1{font-size:36px!important;letter-spacing:-1px!important;}
  .features{padding:60px 24px!important;}
  .features-grid{grid-template-columns:1fr!important;}
  .reviews{padding:60px 24px!important;}
  .reviews-grid{grid-template-columns:1fr!important;}
  .offers-page{padding:80px 16px 40px!important;}
  .offers-grid{grid-template-columns:1fr!important;}
  .b2b-grid{grid-template-columns:1fr!important;}
  .commission-banner{flex-direction:column!important;text-align:center!important;}
  .login-page{flex-direction:column!important;}
  .login-left{padding:60px 24px 40px!important;}
  .login-right{padding:40px 24px!important;}
  .app-layout{flex-direction:column!important;}
  .sidebar{width:100%!important;position:relative!important;top:auto!important;height:auto!important;padding:12px 0!important;}
  .sidebar-user{display:none!important;}
  .sidebar-nav{display:flex!important;flex-wrap:wrap!important;padding:0 8px!important;gap:4px!important;}
  .sidebar-nav li a{padding:8px 12px!important;font-size:12px!important;border-radius:8px!important;}
  .sidebar-section{display:none!important;}
  .main-content{margin-left:0!important;padding:16px!important;}
  .dash-kpis{grid-template-columns:1fr 1fr!important;}
  .dash-grid{grid-template-columns:1fr!important;}
  .domains-grid{grid-template-columns:1fr 1fr!important;}
  .favs-grid{grid-template-columns:1fr!important;}
  .messages-layout{grid-template-columns:1fr!important;height:auto!important;}
  .messages-list{display:none!important;}
  .rdv-grid{grid-template-columns:1fr!important;}
  .courses-grid{grid-template-columns:1fr!important;}
  .footer-grid{grid-template-columns:1fr 1fr!important;}
  .footer-brand{grid-column:1/-1!important;}
  .section-title{font-size:28px!important;}
  .hero-actions{flex-direction:column!important;width:100%!important;}
  .hero-actions .btn-primary,.hero-actions .btn-outline{width:100%!important;text-align:center!important;}
  .nav-mobile-btn{display:flex!important;}
  .mobile-menu{display:block!important;}
}
@media(max-width:480px){
  .dash-kpis{grid-template-columns:1fr!important;}
  .domains-grid{grid-template-columns:1fr!important;}
  .admin-dash-kpis{grid-template-columns:1fr 1fr!important;}
}
@media(min-width:769px) and (max-width:1024px){
  .hero{padding:100px 40px 80px!important;}
  .hero h1{font-size:48px!important;}
  .hero-stats{right:40px!important;}
  .features{padding:60px 40px!important;}
  .features-grid{grid-template-columns:1fr 1fr!important;}
  .reviews-grid{grid-template-columns:1fr 1fr!important;}
  .courses-grid{grid-template-columns:1fr 1fr!important;}
  .offers-page{padding:80px 32px 40px!important;}
  .offers-grid{grid-template-columns:1fr 1fr!important;}
}

/* ── NAV ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(13,27,46,0.97);backdrop-filter:blur(12px);
  height:64px;display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;border-bottom:1px solid rgba(201,168,76,0.2);
}
@media(max-width:768px){.nav{padding:0 16px;}}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--gold);letter-spacing:-0.5px;cursor:pointer;}
.nav-logo span{color:var(--white);}
.nav-links{display:flex;gap:32px;align-items:center;}
.nav-links a{color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;cursor:pointer;transition:color .2s;}
.nav-links a:hover{color:var(--white);}
.nav-right{display:flex;align-items:center;gap:12px;}
.nav-cta{background:var(--gold);color:var(--navy);padding:9px 22px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;transition:all .2s;border:none;font-family:'DM Sans',sans-serif;}
.nav-cta:hover{background:var(--gold-light);transform:translateY(-1px);}
.nav-mobile-btn{display:none;background:none;border:none;cursor:pointer;flex-direction:column;gap:5px;padding:4px;}
.nav-mobile-btn span{display:block;width:22px;height:2px;background:var(--white);border-radius:2px;transition:all .3s;}
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;background:var(--navy);z-index:99;padding:16px;border-bottom:1px solid rgba(255,255,255,0.08);}
.mobile-menu a{display:block;padding:12px 16px;color:rgba(255,255,255,0.8);text-decoration:none;font-size:15px;border-radius:10px;cursor:pointer;}
.mobile-menu a:hover{background:rgba(255,255,255,0.07);color:var(--white);}
.mobile-menu .mob-cta{background:var(--gold);color:var(--navy);text-align:center;margin-top:8px;font-weight:500;}

/* ── PAGES ── */
.page{display:none;min-height:100vh;padding-top:64px;}
.page.active{display:block;}

/* ── SIDEBAR LAYOUT ── */
.app-layout{display:flex;min-height:calc(100vh - 64px);}
.sidebar{
  width:var(--sidebar-w);background:var(--navy);flex-shrink:0;position:fixed;
  top:64px;bottom:0;left:0;overflow-y:auto;padding:24px 0;
  border-right:1px solid rgba(255,255,255,0.06);
}
.sidebar-user{padding:0 20px 24px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:16px;}
.sidebar-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--navy);margin-bottom:10px;}
.sidebar-name{font-size:14px;font-weight:500;color:var(--white);}
.sidebar-role{font-size:12px;color:rgba(255,255,255,0.45);margin-top:2px;}
.sidebar-nav{list-style:none;padding:0 8px;}
.sidebar-nav li{margin-bottom:2px;}
.sidebar-nav li a{
  display:flex;align-items:center;gap:12px;padding:10px 12px;
  border-radius:10px;color:rgba(255,255,255,0.6);text-decoration:none;
  font-size:13.5px;cursor:pointer;transition:all .2s;
}
.sidebar-nav li a:hover{background:rgba(255,255,255,0.07);color:var(--white);}
.sidebar-nav li a.active{background:rgba(201,168,76,0.15);color:var(--gold);}
.sidebar-nav li a .icon{width:18px;height:18px;opacity:0.8;flex-shrink:0;}
.sidebar-nav li a.active .icon{opacity:1;}
.sidebar-section{font-size:10px;font-weight:500;color:rgba(255,255,255,0.25);letter-spacing:1px;text-transform:uppercase;padding:16px 20px 6px;}
.main-content{margin-left:var(--sidebar-w);flex:1;padding:32px 36px;background:var(--cream);min-height:calc(100vh - 64px);}

/* ── HOME ── */
.hero{
  background:var(--navy);min-height:100vh;display:flex;align-items:center;
  position:relative;overflow:hidden;padding:80px 80px 80px;
}
.hero-bg{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 60% 70% at 70% 50%,rgba(201,168,76,0.08) 0%,transparent 70%),radial-gradient(ellipse 40% 50% at 20% 80%,rgba(46,117,182,0.1) 0%,transparent 60%);}
.hero-grid{position:absolute;inset:0;pointer-events:none;opacity:0.03;background-image:linear-gradient(var(--white) 1px,transparent 1px),linear-gradient(90deg,var(--white) 1px,transparent 1px);background-size:60px 60px;}
.hero-content{position:relative;z-index:1;max-width:620px;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.25);border-radius:50px;padding:6px 16px;margin-bottom:28px;}
.hero-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:pulse 2s infinite;}
.hero-badge-text{font-size:12px;color:var(--gold);font-weight:500;letter-spacing:0.3px;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(1.3)}}
.hero h1{font-family:'Syne',sans-serif;font-size:62px;font-weight:800;color:var(--white);line-height:1.05;letter-spacing:-2px;margin-bottom:24px;}
.hero h1 .gold{color:var(--gold);}
.hero p{font-size:17px;color:rgba(255,255,255,0.65);line-height:1.75;margin-bottom:40px;max-width:520px;}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap;}
.btn-primary{background:var(--gold);color:var(--navy);padding:14px 32px;border-radius:50px;font-size:15px;font-weight:500;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .25s;}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,168,76,0.3);}
.btn-outline{background:transparent;color:var(--white);padding:14px 32px;border-radius:50px;font-size:15px;font-weight:400;cursor:pointer;border:1px solid rgba(255,255,255,0.25);font-family:'DM Sans',sans-serif;transition:all .25s;}
.btn-outline:hover{background:rgba(255,255,255,0.07);border-color:rgba(255,255,255,0.5);}
.hero-stats{position:absolute;right:80px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:20px;z-index:1;}
.stat-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:20px 28px;backdrop-filter:blur(8px);}
.stat-num{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:var(--gold);line-height:1;}
.stat-label{font-size:12px;color:rgba(255,255,255,0.45);margin-top:6px;}

/* features */
.features{padding:96px 80px;background:var(--white);}
.section-label{font-size:12px;font-weight:500;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px;}
.section-title{font-family:'Syne',sans-serif;font-size:42px;font-weight:700;color:var(--navy);line-height:1.15;letter-spacing:-1px;margin-bottom:16px;}
.section-sub{font-size:16px;color:var(--text-mid);max-width:520px;line-height:1.7;margin-bottom:56px;}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.feature-card{background:var(--cream);border-radius:20px;padding:32px;border:1px solid var(--border);transition:all .3s;cursor:pointer;}
.feature-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(13,27,46,0.08);}
.feature-icon{width:48px;height:48px;border-radius:14px;background:var(--navy);display:flex;align-items:center;justify-content:center;margin-bottom:20px;}
.feature-icon svg{width:22px;height:22px;fill:var(--gold);}
.feature-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;}
.feature-desc{font-size:14px;color:var(--text-mid);line-height:1.7;}

/* reviews */
.reviews{padding:96px 80px;background:var(--cream);}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px;}
.review-card{background:var(--white);border-radius:20px;padding:28px;border:1px solid var(--border);}
.review-stars{display:flex;gap:3px;margin-bottom:14px;color:var(--gold);font-size:14px;}
.review-text{font-size:14px;color:var(--text-mid);line-height:1.75;font-style:italic;margin-bottom:20px;}
.review-author{display:flex;align-items:center;gap:12px;}
.review-avatar{width:36px;height:36px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;}
.review-name{font-size:14px;font-weight:500;color:var(--navy);}
.review-school{font-size:12px;color:var(--text-light);}

/* ── OFFRES ── */
.offers-page{padding:84px 80px 60px;}
.offers-header{text-align:center;margin-bottom:56px;}
.offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:32px;}
.b2b-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;}
.offer-card{background:var(--white);border-radius:24px;padding:36px;border:1px solid var(--border);position:relative;display:flex;flex-direction:column;}
.offer-card:hover{transform:translateY(-4px);box-shadow:0 20px 50px rgba(13,27,46,0.1);}
.offer-card.featured{border:2px solid var(--gold);background:var(--navy);}
.offer-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--navy);font-size:11px;font-weight:600;padding:4px 18px;border-radius:50px;white-space:nowrap;}
.offer-icon{font-size:32px;margin-bottom:16px;}
.offer-name{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;margin-bottom:6px;}
.offer-card.featured .offer-name{color:var(--white);}
.offer-target{font-size:12px;color:var(--text-light);margin-bottom:20px;}
.offer-card.featured .offer-target{color:rgba(255,255,255,0.5);}
.offer-price{font-family:'Syne',sans-serif;font-size:58px;font-weight:800;color:var(--navy);line-height:1;letter-spacing:-3px;margin:8px 0 4px;}.offer-price-currency{font-size:24px;font-weight:600;vertical-align:super;letter-spacing:0;margin-right:2px;}
.offer-card.featured .offer-price{color:var(--gold);}
.offer-period{font-size:13px;color:var(--text-light);margin-bottom:28px;}
.offer-card.featured .offer-period{color:rgba(255,255,255,0.4);}
.offer-divider{border:none;border-top:1px solid var(--border);margin-bottom:24px;}
.offer-card.featured .offer-divider{border-top-color:rgba(255,255,255,0.1);}
.offer-features{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:32px;flex:1;}
.offer-features li{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:var(--text-mid);line-height:1.5;}
.offer-card.featured .offer-features li{color:rgba(255,255,255,0.75);}
.offer-check{width:18px;height:18px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.offer-card.featured .offer-check{background:rgba(201,168,76,0.2);}
.offer-check svg{width:10px;height:10px;fill:var(--green);}
.offer-card.featured .offer-check svg{fill:var(--gold);}
/* Bouton aligné en bas */
.offer-btn{width:100%;padding:13px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;border:1px solid var(--navy);background:transparent;color:var(--navy);font-family:'DM Sans',sans-serif;transition:all .2s;margin-top:auto;}
.offer-btn:hover{background:var(--navy);color:var(--white);}
.offer-card.featured .offer-btn{background:var(--gold);color:var(--navy);border-color:var(--gold);}
.offer-card.featured .offer-btn:hover{background:var(--gold-light);}
.commission-banner{background:var(--navy);border-radius:20px;padding:32px 40px;display:flex;align-items:center;justify-content:space-between;gap:24px;}
.commission-text h3{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--white);margin-bottom:8px;}
.commission-text p{font-size:14px;color:rgba(255,255,255,0.6);max-width:500px;line-height:1.6;}
.commission-amounts{display:flex;gap:24px;flex-shrink:0;}
.comm-item{text-align:center;}
.comm-amount{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--gold);}
.comm-label{font-size:11px;color:rgba(255,255,255,0.4);margin-top:4px;}

/* ── LOGIN ── */
.login-page{min-height:100vh;display:flex;align-items:stretch;padding-top:0!important;}
.login-left{flex:1;background:var(--navy);padding:80px;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;}
.login-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 100%,rgba(201,168,76,0.1) 0%,transparent 70%);pointer-events:none;}
.login-left h2{font-family:'Syne',sans-serif;font-size:44px;font-weight:800;color:var(--white);line-height:1.1;letter-spacing:-1.5px;margin-bottom:20px;position:relative;z-index:1;}
.login-left h2 .gold{color:var(--gold);}
.login-left p{font-size:16px;color:rgba(255,255,255,0.55);line-height:1.7;max-width:380px;position:relative;z-index:1;}
.login-testimonial{margin-top:40px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:24px;position:relative;z-index:1;max-width:420px;}
.login-testimonial p{font-size:14px;color:rgba(255,255,255,0.75);font-style:italic;line-height:1.65;margin-bottom:14px;}
.login-testimonial-author{font-size:13px;color:var(--gold);font-weight:500;}
.login-right{flex:1;background:var(--white);padding:60px 80px;display:flex;flex-direction:column;justify-content:center;align-items:center;overflow-y:auto;}
.login-form{width:100%;max-width:420px;}
.login-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;color:var(--navy);margin-bottom:6px;}
.login-logo span{color:var(--gold);}
.login-subtitle{font-size:14px;color:var(--text-light);margin-bottom:28px;}
.login-tabs{display:flex;background:var(--cream);border-radius:12px;padding:4px;margin-bottom:24px;}
.login-tab{flex:1;padding:9px;text-align:center;border-radius:9px;font-size:13.5px;cursor:pointer;transition:all .2s;color:var(--text-light);}
.login-tab.active{background:var(--white);color:var(--navy);font-weight:500;box-shadow:0 1px 4px rgba(0,0,0,0.08);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:480px){.form-row{grid-template-columns:1fr;}}
.form-group{margin-bottom:14px;}
.form-label{font-size:13px;font-weight:500;color:var(--navy);margin-bottom:5px;display:block;}
.form-input{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:12px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--navy);background:var(--cream);transition:border .2s;outline:none;}
.form-input:focus{border-color:var(--navy-mid);background:var(--white);}
.form-select{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:12px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--navy);background:var(--cream);outline:none;appearance:none;cursor:pointer;}
.form-btn{width:100%;padding:14px;background:var(--navy);color:var(--white);border:none;border-radius:50px;font-size:15px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .25s;margin-top:6px;}
.form-btn:hover{background:var(--navy-mid);transform:translateY(-1px);}
.form-divider{display:flex;align-items:center;gap:12px;margin:18px 0;}
.form-divider::before,.form-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.form-divider span{font-size:12px;color:var(--text-light);}
.social-btns{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.social-btn{padding:11px;border:1px solid var(--border);border-radius:12px;background:transparent;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;display:flex;align-items:center;justify-content:center;gap:8px;transition:background .2s;}
.social-btn:hover{background:var(--cream);}
#register-fields{display:none;}

/* ── DASHBOARD ── */
.dash-header{margin-bottom:28px;}
.dash-header h1{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;color:var(--navy);letter-spacing:-0.5px;}
.dash-header p{font-size:14px;color:var(--text-light);margin-top:4px;}
.dash-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.kpi-card{background:var(--white);border-radius:16px;padding:20px 22px;border:1px solid var(--border);}
.kpi-label{font-size:12px;color:var(--text-light);margin-bottom:8px;}
.kpi-value{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;color:var(--navy);}
.kpi-change{font-size:12px;margin-top:4px;}
.kpi-up{color:var(--green);}
.dash-grid{display:grid;grid-template-columns:1fr 320px;gap:20px;}
.dash-card{background:var(--white);border-radius:16px;padding:24px;border:1px solid var(--border);}
.dash-card-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;color:var(--navy);margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;}
.dash-card-title span{font-size:12px;color:var(--gold);font-weight:400;cursor:pointer;font-family:'DM Sans',sans-serif;}
.activity-list{display:flex;flex-direction:column;gap:14px;}
.activity-item{display:flex;gap:14px;align-items:flex-start;}
.activity-avatar{width:36px;height:36px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:var(--gold);flex-shrink:0;}
.activity-info{flex:1;}
.activity-name{font-size:13.5px;font-weight:500;color:var(--navy);}
.activity-desc{font-size:12px;color:var(--text-light);margin-top:2px;}
.activity-time{font-size:11px;color:var(--text-light);white-space:nowrap;}
.upcoming-list{display:flex;flex-direction:column;gap:10px;}
.rdv-item{background:var(--cream);border-radius:12px;padding:14px 16px;border-left:3px solid var(--gold);}
.rdv-name{font-size:13.5px;font-weight:500;color:var(--navy);}
.rdv-date{font-size:12px;color:var(--text-light);margin-top:3px;}
.rdv-type{display:inline-block;font-size:11px;background:rgba(201,168,76,0.12);color:var(--gold);padding:2px 10px;border-radius:50px;margin-top:8px;}
.progress-bar-wrap{background:var(--border);border-radius:50px;height:5px;overflow:hidden;}
.progress-bar-fill{height:100%;background:var(--gold);border-radius:50px;}

/* ── RECHERCHE ── */
.search-hero{background:var(--navy);padding:40px 32px 48px;border-radius:20px;margin-bottom:24px;position:relative;overflow:hidden;}
.search-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(201,168,76,0.1) 0%,transparent 70%);}
.search-hero h2{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;color:var(--white);margin-bottom:6px;position:relative;}
.search-hero p{font-size:14px;color:rgba(255,255,255,0.55);margin-bottom:24px;position:relative;}
.search-bar{display:flex;gap:10px;position:relative;}
.search-input{flex:1;padding:13px 18px;border-radius:50px;border:none;font-size:15px;font-family:'DM Sans',sans-serif;outline:none;}
.search-btn{background:var(--gold);color:var(--navy);border:none;padding:13px 24px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;}
.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.filter-tag{background:var(--white);border:1px solid var(--border);border-radius:50px;padding:6px 16px;font-size:13px;cursor:pointer;transition:all .2s;color:var(--text-mid);}
.filter-tag:hover,.filter-tag.active{background:var(--navy);color:var(--white);border-color:var(--navy);}
.domains-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.domain-card{background:var(--white);border-radius:16px;padding:24px;border:1px solid var(--border);cursor:pointer;transition:all .25s;}
.domain-card:hover{border-color:var(--navy-mid);transform:translateY(-2px);box-shadow:0 8px 24px rgba(13,27,46,0.08);}
.domain-icon{font-size:28px;margin-bottom:12px;}
.domain-name{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;color:var(--navy);margin-bottom:6px;}
.domain-count{font-size:12px;color:var(--text-light);}
.domain-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px;}
.domain-tag{background:var(--cream);color:var(--text-mid);font-size:11px;padding:3px 10px;border-radius:50px;}

/* Progression section dans Recherche */
.progression-section{background:var(--white);border-radius:20px;border:1px solid var(--border);padding:32px;margin-bottom:24px;}
.prog-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:600;color:var(--navy);margin-bottom:20px;}
.prog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
@media(max-width:768px){.prog-grid{grid-template-columns:1fr;}}
.prog-card{background:var(--cream);border-radius:16px;padding:24px;cursor:pointer;transition:all .25s;border:1px solid transparent;}.prog-card:hover{background:var(--white);border-color:var(--gold);transform:translateY(-3px);box-shadow:0 8px 24px rgba(13,27,46,0.08);}
.prog-card-name{font-size:15px;font-weight:600;color:var(--navy);margin-bottom:4px;}
.prog-card-sub{font-size:12px;color:var(--text-light);margin-bottom:12px;}
.prog-pct{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;color:var(--gold);margin-bottom:10px;line-height:1;}

/* ── FAVORIS ── */
.favs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
.fav-card{background:var(--white);border-radius:16px;padding:22px;border:1px solid var(--border);display:flex;gap:14px;align-items:flex-start;}
.fav-avatar{width:50px;height:50px;border-radius:14px;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--gold);flex-shrink:0;}
.fav-info{flex:1;}
.fav-name{font-size:15px;font-weight:500;color:var(--navy);margin-bottom:3px;}
.fav-role{font-size:12px;color:var(--text-light);margin-bottom:10px;}
.fav-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
.fav-tag{background:var(--cream);color:var(--text-mid);font-size:11px;padding:3px 10px;border-radius:50px;}
.fav-actions{display:flex;gap:8px;}
.fav-btn{padding:7px 16px;border-radius:50px;font-size:12.5px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;}
.fav-btn-primary{background:var(--navy);color:var(--white);border:none;}
.fav-btn-outline{background:transparent;color:var(--navy);border:1px solid var(--border);}
.fav-btn:hover{opacity:0.8;}
.fav-heart{margin-left:auto;color:#E24B4A;font-size:20px;cursor:pointer;}

/* ── MESSAGES ── */
.messages-layout{display:grid;grid-template-columns:280px 1fr;gap:0;background:var(--white);border-radius:20px;border:1px solid var(--border);overflow:hidden;height:calc(100vh - 160px);}
.messages-list{border-right:1px solid var(--border);overflow-y:auto;}
.messages-search{padding:14px;border-bottom:1px solid var(--border);}
.msg-search-input{width:100%;padding:9px 14px;border:1px solid var(--border);border-radius:10px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;background:var(--cream);}
.conv-item{padding:13px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s;display:flex;gap:10px;align-items:flex-start;}
.conv-item:hover{background:var(--cream);}
.conv-item.active{background:rgba(201,168,76,0.06);border-left:3px solid var(--gold);}
.conv-avatar{width:38px;height:38px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;}
.conv-body{flex:1;min-width:0;}
.conv-name{font-size:13px;font-weight:500;color:var(--navy);}
.conv-preview{font-size:12px;color:var(--text-light);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;}
.conv-meta{display:flex;flex-direction:column;align-items:flex-end;gap:4px;}
.conv-time{font-size:11px;color:var(--text-light);}
.conv-badge{background:var(--navy);color:var(--white);border-radius:50%;width:17px;height:17px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;}
.chat-area{display:flex;flex-direction:column;height:100%;}
.chat-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;}
.chat-header .conv-avatar{width:34px;height:34px;font-size:11px;}
.chat-header-info h4{font-size:14px;font-weight:500;color:var(--navy);}
.chat-header-info p{font-size:12px;color:var(--text-light);}
.chat-messages{flex:1;padding:18px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;}
.msg{max-width:68%;}
.msg-in{align-self:flex-start;}
.msg-out{align-self:flex-end;}
.msg-bubble{padding:10px 15px;border-radius:16px;font-size:14px;line-height:1.6;}
.msg-in .msg-bubble{background:var(--cream);color:var(--text-dark);border-radius:4px 16px 16px 16px;}
.msg-out .msg-bubble{background:var(--navy);color:var(--white);border-radius:16px 4px 16px 16px;}
.msg-time{font-size:11px;color:var(--text-light);margin-top:4px;}
.msg-out .msg-time{text-align:right;}
.chat-input-area{padding:14px 18px;border-top:1px solid var(--border);display:flex;gap:10px;align-items:center;}
.chat-input{flex:1;padding:10px 14px;border:1px solid var(--border);border-radius:50px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;}
.chat-send{background:var(--navy);color:var(--white);border:none;width:38px;height:38px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* ── RDV ── */
.rdv-grid{display:grid;grid-template-columns:1fr 300px;gap:20px;}
.calendar-card{background:var(--white);border-radius:20px;border:1px solid var(--border);padding:24px;}
.cal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
.cal-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:600;color:var(--navy);}
.cal-nav{display:flex;gap:6px;}
.cal-nav-btn{width:30px;height:30px;border:1px solid var(--border);border-radius:8px;background:transparent;cursor:pointer;font-size:14px;color:var(--text-mid);display:flex;align-items:center;justify-content:center;transition:all .2s;}
.cal-nav-btn:hover{background:var(--navy);color:var(--white);border-color:var(--navy);}
.cal-days-header{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px;}
.cal-day-name{text-align:center;font-size:11px;color:var(--text-light);padding:6px 2px;font-weight:500;}
/* Quadrillage calendrier */
.cal-days{display:grid;grid-template-columns:repeat(7,1fr);gap:0;border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.cal-day{
  aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:13px;cursor:pointer;transition:all .15s;color:var(--text-mid);
  border-right:1px solid var(--border);border-bottom:1px solid var(--border);
  position:relative;padding:4px;
}
.cal-day:nth-child(7n){border-right:none;}
.cal-day:nth-last-child(-n+7){border-bottom:none;}
.cal-day:hover{background:rgba(201,168,76,0.08);}
.cal-day.today{background:var(--navy);color:var(--white);font-weight:600;}
.cal-day.today:hover{background:var(--navy-mid);}
.cal-day.has-event{color:var(--navy);font-weight:500;}
.cal-day.has-event::after{content:'';position:absolute;bottom:4px;width:5px;height:5px;border-radius:50%;background:var(--gold);}
.cal-day.other-month{color:var(--border);background:var(--cream);}
.cal-day.selected{background:rgba(201,168,76,0.15);color:var(--navy);font-weight:600;}
.rdv-side{display:flex;flex-direction:column;gap:14px;}
.rdv-side-card{background:var(--white);border-radius:16px;border:1px solid var(--border);padding:20px;}
.rdv-side-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:600;color:var(--navy);margin-bottom:14px;}
.rdv-slot{background:var(--cream);border-radius:10px;padding:11px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s;border:1px solid transparent;}
.rdv-slot:hover{border-color:var(--gold);background:var(--gold-pale);}
.rdv-slot-time{font-size:13px;font-weight:500;color:var(--navy);}
.rdv-slot-type{font-size:12px;color:var(--text-light);margin-top:2px;}
.new-rdv-btn{width:100%;padding:12px;background:var(--gold);color:var(--navy);border:none;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;}
.new-rdv-btn:hover{background:var(--gold-light);}

/* ── ACADEMY ── */
.academy-hero{background:var(--navy);border-radius:20px;padding:36px 40px;margin-bottom:24px;position:relative;overflow:hidden;}
.academy-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 80% at 90% 50%,rgba(201,168,76,0.12) 0%,transparent 70%);}
.academy-hero h2{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;color:var(--white);margin-bottom:6px;position:relative;}
.academy-hero p{font-size:14px;color:rgba(255,255,255,0.55);max-width:520px;line-height:1.7;position:relative;}
.academy-stats{display:flex;gap:32px;margin-top:24px;position:relative;}
.acad-stat-num{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--gold);}
.acad-stat-label{font-size:12px;color:rgba(255,255,255,0.4);margin-top:2px;}

/* Academy toolbar */
.academy-toolbar{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:20px;}
.academy-search{flex:1;min-width:200px;display:flex;gap:8px;}
.academy-search input{flex:1;padding:9px 16px;border:1px solid var(--border);border-radius:50px;font-size:13.5px;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);}
.academy-search input:focus{border-color:var(--navy-mid);}
.academy-cats{display:flex;gap:8px;flex-wrap:wrap;}
.academy-cat{background:var(--white);border:1px solid var(--border);border-radius:50px;padding:7px 16px;font-size:13px;cursor:pointer;transition:all .2s;color:var(--text-mid);}
.academy-cat:hover,.academy-cat.active{background:var(--navy);color:var(--white);border-color:var(--navy);}
.level-filter{padding:9px 14px;border:1px solid var(--border);border-radius:50px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);cursor:pointer;color:var(--text-mid);}
.courses-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.course-card{background:var(--white);border-radius:20px;overflow:hidden;border:1px solid var(--border);cursor:pointer;transition:all .3s;display:flex;flex-direction:column;}
.course-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(13,27,46,0.1);}
.course-thumb{height:130px;display:flex;align-items:center;justify-content:center;font-size:44px;position:relative;}
.course-duration{position:absolute;bottom:8px;right:8px;background:rgba(13,27,46,0.75);color:var(--white);font-size:11px;padding:3px 10px;border-radius:50px;backdrop-filter:blur(4px);}
.course-body{padding:18px;flex:1;display:flex;flex-direction:column;}
.course-tag{display:inline-block;font-size:11px;background:rgba(201,168,76,0.12);color:var(--gold);padding:3px 10px;border-radius:50px;margin-bottom:8px;}
.course-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:600;color:var(--navy);margin-bottom:6px;line-height:1.3;}
.course-desc{font-size:12px;color:var(--text-light);line-height:1.6;margin-bottom:12px;flex:1;}
.course-footer{display:flex;justify-content:space-between;align-items:center;}
.course-modules{font-size:12px;color:var(--text-light);}
.course-level{font-size:11px;padding:3px 10px;border-radius:50px;}
.level-debutant{background:var(--green-light);color:var(--green);}
.level-intermediaire{background:rgba(201,168,76,0.12);color:#8B6914;}
.level-avance{background:rgba(13,27,46,0.08);color:var(--navy-mid);}
.level-lycee{background:rgba(46,117,182,0.1);color:var(--navy-mid);}
.level-tous{background:var(--cream);color:var(--text-mid);}

/* ── FOOTER ── */
footer{background:var(--navy);color:var(--white);padding:64px 80px 32px;}
@media(max-width:768px){footer{padding:48px 24px 24px;}}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:48px;}
@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:32px;}}
.footer-brand{}
.footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:var(--gold);margin-bottom:14px;}
.footer-logo span{color:var(--white);}
.footer-tagline{font-size:14px;color:rgba(255,255,255,0.5);line-height:1.7;max-width:240px;margin-bottom:24px;}
.footer-socials{display:flex;gap:10px;}
.footer-social{width:36px;height:36px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;text-decoration:none;}
.footer-social:hover{background:rgba(201,168,76,0.15);border-color:var(--gold);}
.footer-social svg{width:16px;height:16px;}
.footer-col h4{font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--white);margin-bottom:16px;letter-spacing:0.3px;}
.footer-col ul{list-style:none;}
.footer-col ul li{margin-bottom:10px;}
.footer-col ul li a{font-size:13.5px;color:rgba(255,255,255,0.5);text-decoration:none;cursor:pointer;transition:color .2s;}
.footer-col ul li a:hover{color:var(--gold);}
.footer-contact{display:flex;flex-direction:column;gap:10px;}
.footer-contact-item{display:flex;align-items:flex-start;gap:10px;}
.footer-contact-icon{width:16px;height:16px;flex-shrink:0;margin-top:2px;opacity:0.5;}
.footer-contact-text{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.5;}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.08);padding-top:28px;display:flex;justify-content:space-between;align-items:center;flex-wrap:gap;gap:16px;}
@media(max-width:768px){.footer-bottom{flex-direction:column;text-align:center;}}
.footer-bottom p{font-size:13px;color:rgba(255,255,255,0.3);}
.footer-bottom-links{display:flex;gap:24px;}
.footer-bottom-links a{font-size:13px;color:rgba(255,255,255,0.3);text-decoration:none;cursor:pointer;transition:color .2s;}
.footer-bottom-links a:hover{color:var(--gold);}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:rgba(13,27,46,0.15);border-radius:50px;}

  /* ── ROLES ADMIN / USER ── */
  .admin-only { display: none; }
  .user-only  { display: block; }
  body.role-admin .admin-only { display: block; }
  body.role-admin .user-only  { display: none; }
  body.role-admin .admin-only-flex { display: flex; }
  .admin-only-flex { display: none; }

  /* Badge role dans sidebar */
  .role-badge-admin { display:none; background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--navy); font-size:10px; font-weight:700; padding:2px 10px; border-radius:50px; letter-spacing:0.5px; }
  .role-badge-user  { display:inline-block; background:rgba(46,117,182,0.2); color:var(--navyMed,#2E75B6); font-size:10px; font-weight:600; padding:2px 10px; border-radius:50px; }
  body.role-admin .role-badge-admin { display:inline-block; }
  body.role-admin .role-badge-user  { display:none; }

  /* Hint sur page login */
  .login-hint { background:rgba(201,168,76,0.08); border:1px solid rgba(201,168,76,0.2); border-radius:10px; padding:10px 14px; margin-bottom:16px; font-size:12px; color:var(--text-mid); line-height:1.6; }

  /* Panel admin dans l'académie */
  .academy-admin-panel { background:var(--navy); border-radius:16px; padding:24px; margin-bottom:24px; border:2px solid var(--gold); }
  .academy-admin-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; color:var(--white); margin-bottom:16px; display:flex; align-items:center; gap:10px; }
  .academy-admin-title span { background:var(--gold); color:var(--navy); font-size:10px; font-weight:700; padding:2px 8px; border-radius:50px; }
  .admin-module-list { display:flex; flex-direction:column; gap:8px; }
  .admin-module-item { background:rgba(255,255,255,0.05); border-radius:10px; padding:12px 16px; display:flex; align-items:center; gap:12px; border:1px solid rgba(255,255,255,0.08); }
  .admin-module-name { flex:1; font-size:13.5px; color:rgba(255,255,255,0.85); }
  .admin-module-count { font-size:12px; color:var(--gold); }
  .admin-add-btn { background:var(--gold); color:var(--navy); border:none; padding:7px 16px; border-radius:50px; font-size:12px; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .2s; white-space:nowrap; }
  .admin-add-btn:hover { background:var(--gold-light); }

  /* Lecteur vidéo dans les cards user */
  .video-player-section { margin-top:12px; border-top:1px solid var(--border); padding-top:12px; display:none; }
  .video-player-section.has-videos { display:block; }
  .video-pill { display:inline-flex; align-items:center; gap:6px; background:var(--green-light); color:var(--green); font-size:11px; padding:4px 12px; border-radius:50px; cursor:pointer; margin:3px 3px 0 0; font-weight:500; transition:all .2s; border:1px solid transparent; }
  .video-pill:hover { background:var(--green); color:white; }
  .video-embed-area { margin-top:10px; border-radius:12px; overflow:hidden; display:none; }


  /* ── PROFIL ── */
  .pf-card{background:var(--white);border-radius:20px;padding:28px;border:1px solid var(--border);margin-bottom:18px;}
  .pf-header{display:flex;align-items:center;gap:16px;margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid var(--border);}
  .pf-av{width:64px;height:64px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:20px;font-weight:700;color:var(--gold);flex-shrink:0;}
  .pf-name{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;color:var(--navy);}
  .pf-role{font-size:12.5px;color:var(--text-light);margin-top:3px;}
  .pf-badge{display:inline-block;font-size:11px;background:rgba(201,168,76,.12);color:#8B6914;padding:3px 10px;border-radius:50px;font-weight:600;margin-top:6px;}
  .pf-bio{background:var(--cream);border-radius:12px;padding:14px 16px;border-left:3px solid var(--gold);font-size:13.5px;color:var(--text-mid);line-height:1.7;margin-bottom:16px;}
  .pf-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .pf-field label{font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px;display:block;}
  .pf-field input,.pf-field select,.pf-field textarea{width:100%;padding:9px 13px;border:1.5px solid var(--border);border-radius:9px;font-size:13.5px;font-family:'DM Sans',sans-serif;color:var(--navy);outline:none;transition:border .2s;}
  .pf-field input:focus,.pf-field select:focus,.pf-field textarea:focus{border-color:var(--gold);}
  .pf-field-full{grid-column:1/-1;}
  .pf-section{font-family:'Syne',sans-serif;font-size:14px;font-weight:600;color:var(--navy);margin:18px 0 10px;padding-top:14px;border-top:1px solid var(--border);}
  .pf-save{background:var(--navy);color:white;border:none;padding:11px 26px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;}
  .pf-save:hover{background:var(--navy-mid);}
  .pf-cancel{background:transparent;border:1px solid var(--border);color:var(--text-mid);padding:11px 22px;border-radius:50px;font-size:14px;cursor:pointer;font-family:'DM Sans',sans-serif;margin-left:8px;}

  /* ── AVIS ── */
  .avis-card{background:var(--white);border-radius:16px;padding:20px;border:1px solid var(--border);margin-bottom:12px;}
  .avis-header{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
  .avis-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;flex-shrink:0;}
  .stars-input span{font-size:26px;cursor:pointer;color:#DDD;transition:color .15s;}
  .stars-input span.on{color:#F5A623;}
  .stars-display{font-size:16px;color:#F5A623;}
  .avis-urgent{background:rgba(226,75,74,.06);border:1px solid rgba(226,75,74,.2);border-radius:10px;padding:12px 16px;font-size:13px;color:var(--red);margin-bottom:12px;display:flex;align-items:center;gap:10px;}
  .avis-comment{width:100%;padding:9px 13px;border:1.5px solid var(--border);border-radius:9px;font-size:13.5px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;min-height:90px;transition:border .2s;}
  .avis-comment:focus{border-color:var(--gold);}

  /* ── STAGE & ALTERNANCE ── */
  .sec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:18px;}
  @media(max-width:768px){.sec-grid{grid-template-columns:1fr 1fr;}}
  .sec-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:13px;cursor:pointer;text-align:center;transition:all .15s;}
  .sec-card:hover,.sec-card.on{border-color:var(--navy);background:var(--navy);}
  .sec-card:hover *,.sec-card.on *{color:white!important;}
  .jf-btn{background:var(--white);border:1px solid var(--border);border-radius:50px;padding:5px 13px;font-size:12px;cursor:pointer;color:var(--text-mid);transition:all .15s;font-family:'DM Sans',sans-serif;}
  .jf-btn.on{background:var(--navy);color:white;border-color:var(--navy);}
  .job-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:14px;cursor:pointer;transition:all .15s;}
  .job-card:hover{border-color:var(--navy-mid);}
  .job-type-pill{font-size:11px;padding:2px 8px;border-radius:50px;font-weight:500;display:inline-block;}
  .jp-stage{background:rgba(30,126,52,.1);color:var(--green);}
  .jp-alternance{background:rgba(46,117,182,.1);color:var(--navy-mid);}
  .jp-cdi{background:rgba(201,168,76,.12);color:#8B6914;}

  /* ── ADMIN CALENDRIER ── */
  .wg{display:grid;grid-template-columns:50px repeat(6,1fr);border:1px solid var(--border);border-radius:11px;overflow:hidden;}
  .wg-h{background:var(--navy);color:white;padding:6px 2px;font-size:9px;text-align:center;font-weight:500;border-right:1px solid rgba(255,255,255,.1);}
  .wg-t{font-size:8.5px;color:var(--text-light);padding:2px 4px;text-align:right;border-right:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--cream);height:30px;display:flex;align-items:center;justify-content:flex-end;}
  .wg-c{border-right:1px solid var(--border);border-bottom:1px solid var(--border);height:30px;cursor:pointer;transition:background .1s;display:flex;align-items:center;justify-content:center;font-size:8px;}
  .wg-c.av{background:rgba(30,126,52,.12);}
  .wg-c.av:hover{background:rgba(30,126,52,.22);}
  .wg-c.bl{background:rgba(226,75,74,.1);cursor:not-allowed;color:var(--red);}
  .wg-c.bk{background:rgba(201,168,76,.18);color:var(--gold);}

  /* ── PRO CARDS ── */
  .pro-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:13px;}
  .pro-card{background:var(--white);border-radius:14px;padding:18px;border:1px solid var(--border);display:flex;gap:12px;transition:all .2s;}
  .pro-card:hover{box-shadow:var(--shadow);transform:translateY(-2px);}
  .pro-av{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;flex-shrink:0;}
  .pro-btn{padding:5px 12px;border-radius:50px;font-size:11.5px;cursor:pointer;font-family:'DM Sans',sans-serif;border:1px solid var(--border);background:transparent;color:var(--navy);transition:all .15s;}
  .pro-btn.pri{background:var(--navy);color:white;border-color:var(--navy);}

  /* ── FICHE PILL ── */
  .fiche-pill{display:inline-block;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.25);border-radius:7px;padding:5px 9px;margin:2px 2px 0 0;cursor:pointer;font-size:11px;color:var(--navy);transition:all .15s;}
  .fiche-pill:hover{background:rgba(201,168,76,.2);}

  /* ── EMAIL TOAST ── */
  .email-toast{position:fixed;bottom:24px;right:24px;background:white;border:1px solid var(--border);border-radius:16px;padding:16px 20px;width:310px;box-shadow:0 8px 30px rgba(13,27,46,.14);z-index:9999;transform:translateY(20px);opacity:0;transition:all .4s;}
  .email-toast.show{transform:translateY(0);opacity:1;}

  /* ── MODALES ── */
  .p14-mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;align-items:center;justify-content:center;}
  .p14-mb{background:var(--white);border-radius:22px;padding:28px;width:500px;max-width:94vw;max-height:88vh;overflow-y:auto;position:relative;}
  .p14-mc{position:absolute;top:11px;right:13px;background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-light);}
  .p14-mt{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--navy);margin-bottom:16px;}

</style>
