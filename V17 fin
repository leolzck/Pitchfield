function p14LoadProfil(){
  if(!currentUser)return;
  var email=Object.keys(USERS).find(function(k){return USERS[k]===currentUser;})||'';
  var p=P14_PROFILES[email]||{};
  var av=document.getElementById('pf-av-big');
  if(av)av.textContent=currentUser.initials||(currentUser.name||'').slice(0,2).toUpperCase();
  var nm=document.getElementById('pf-name-display');if(nm)nm.textContent=currentUser.name||'';
  var rl=document.getElementById('pf-role-display');if(rl)rl.textContent=currentUser.roleLabel||'';
  var bg=document.getElementById('pf-badge');
  if(bg){var bm={admin:'👑 Admin',pro:'🏢 Pro',user:'👤 Étudiant'};bg.textContent=bm[currentUser.role]||currentUser.role;}
  var bio=document.getElementById('pf-bio-display');
  if(bio)bio.innerHTML=p.bio?p.bio:'<span style="color:var(--text-light);font-style:italic;">Aucun résumé — cliquez sur Modifier.</span>';
  var fd=document.getElementById('pf-fields-display');
  if(fd){
    var fields=[
      {l:'Email',v:email},{l:'École',v:p.school||'—'},{l:'Niveau',v:p.level||'—'},
      {l:'Secteur',v:p.sector||'—'},{l:'Ville',v:p.city||'—'},
      {l:'LinkedIn',v:p.linkedin?'<a href="'+p.linkedin+'" target="_blank" style="color:var(--navy-mid);">Voir profil</a>':'—'},
    ];
    if(currentUser.role==='pro'){
      fields=[
        {l:'Email',v:email},{l:'Titre',v:currentUser.roleLabel||'—'},{l:'Ville',v:p.city||'—'},
        {l:'Spécialités',v:(p.specs||'').replace(/,/g,' · ')||'—'},
        {l:'LinkedIn',v:p.linkedin?'<a href="'+p.linkedin+'" target="_blank" style="color:var(--navy-mid);">Voir profil</a>':'—'},
        {l:'Lieu de rencontre',v:p.lieu||'—'},
      ];
    }
    fd.innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'+fields.map(function(f){
      return '<div><div style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:.7px;margin-bottom:3px;">'+f.l+'</div><div style="font-size:13.5px;color:var(--navy);">'+f.v+'</div></div>';
    }).join('')+'</div>';
  }
}

function p14ToggleProfil(show){
  var view=document.getElementById('pf-view');
  var btn=document.getElementById('pf-edit-btn');
  var formBtns=document.getElementById('pf-form-btns');
  var formUser=document.getElementById('pf-form-user');
  var formPro=document.getElementById('pf-form-pro');
  if(view)view.style.display=show?'none':'block';
  if(btn)btn.style.display=show?'none':'';
  if(formBtns)formBtns.style.display=show?'flex':'none';
  var email=Object.keys(USERS).find(function(k){return USERS[k]===currentUser;})||'';
  var p=P14_PROFILES[email]||{};
  var role=currentUser?currentUser.role:'user';
  var isPro=(role==='pro'||role==='admin');
  if(formUser)formUser.style.display=(show&&!isPro)?'block':'none';
  if(formPro)formPro.style.display=(show&&isPro)?'block':'none';
  if(show){
    if(!isPro){
      ['pf-prenom','pf-nom','pf-email','pf-school','pf-sector','pf-bio','pf-langues','pf-diplomes','pf-linkedin','pf-tel','pf-city'].forEach(function(id){
        var el=document.getElementById(id);if(!el)return;
        var map={
          'pf-prenom':p.prenom,'pf-nom':p.nom,'pf-email':email,'pf-school':p.school,
          'pf-sector':p.sector,'pf-bio':p.bio,'pf-langues':p.langues,'pf-diplomes':p.diplomes,
          'pf-linkedin':p.linkedin,'pf-tel':p.tel,'pf-city':p.city,
        };
        el.value=map[id]||'';
      });
      var lg=document.getElementById('pf-level');if(lg)lg.value=p.level||'';
      var go=document.getElementById('pf-obj');if(go)go.value=p.objective||'';
      var gh=document.getElementById('pf-handicap');if(gh)gh.value=p.handicap||'';
    } else {
      ['pf-pro-prenom','pf-pro-nom','pf-pro-co','pf-pro-email','pf-pro-sector','pf-pro-bio','pf-pro-langues','pf-pro-diplomes','pf-pro-linkedin','pf-pro-tel','pf-pro-city','pf-pro-specs','pf-pro-exp'].forEach(function(id){
        var el=document.getElementById(id);if(!el)return;
        var map={
          'pf-pro-prenom':p.prenom,'pf-pro-nom':p.nom,'pf-pro-co':currentUser.roleLabel,
          'pf-pro-email':email,'pf-pro-sector':p.sector,'pf-pro-bio':p.bio,
          'pf-pro-langues':p.langues,'pf-pro-diplomes':p.diplomes,'pf-pro-linkedin':p.linkedin,
          'pf-pro-tel':p.tel,'pf-pro-city':p.city,'pf-pro-specs':p.specs||'','pf-pro-exp':p.exp||'',
        };
        el.value=map[id]||'';
      });
      var dmt=document.getElementById('pf-pro-domaine');if(dmt)dmt.value=p.domaine||'';
      var lt=document.getElementById('pf-pro-lieu');if(lt)lt.value=p.lieu||'';
      var ambt=document.getElementById('pf-pro-ambassador');if(ambt)ambt.value=p.ambassador||'non';
    }
  }
}

function p14SaveProfil(){
  var email=Object.keys(USERS).find(function(k){return USERS[k]===currentUser;})||'';
  var p=P14_PROFILES[email]||{};
  var isPro=currentUser&&(currentUser.role==='pro'||currentUser.role==='admin');
  if(!isPro){
    p.prenom=g('pf-prenom');p.nom=g('pf-nom');p.school=g('pf-school');
    p.sector=g('pf-sector');p.bio=g('pf-bio');p.langues=g('pf-langues');
    p.diplomes=g('pf-diplomes');p.linkedin=g('pf-linkedin');p.tel=g('pf-tel');
    p.city=g('pf-city');
    var lv=document.getElementById('pf-level');if(lv)p.level=lv.value;
    var ov=document.getElementById('pf-obj');if(ov)p.objective=ov.value;
    var hv=document.getElementById('pf-handicap');if(hv)p.handicap=hv.value;
    var pv=document.getElementById('pf-pwd');if(pv&&pv.value.length>=8){USERS[email].pwd=pv.value;}
    currentUser.name=p.prenom+' '+p.nom;
    if(p.level)currentUser.roleLabel=p.level;
  } else {
    p.prenom=g('pf-pro-prenom');p.nom=g('pf-pro-nom');p.sector=g('pf-pro-sector');
    p.bio=g('pf-pro-bio');p.langues=g('pf-pro-langues');p.diplomes=g('pf-pro-diplomes');
    p.linkedin=g('pf-pro-linkedin');p.tel=g('pf-pro-tel');p.city=g('pf-pro-city');
    p.specs=g('pf-pro-specs');p.exp=g('pf-pro-exp');
    var dv=document.getElementById('pf-pro-domaine');if(dv)p.domaine=dv.value;
    var liev=document.getElementById('pf-pro-lieu');if(liev)p.lieu=liev.value;
    var ambv=document.getElementById('pf-pro-ambassador');if(ambv)p.ambassador=ambv.value;
    var pv2=document.getElementById('pf-pro-pwd');if(pv2&&pv2.value.length>=8){USERS[email].pwd=pv2.value;}
    currentUser.name=p.prenom+' '+p.nom;
    var tiv=g('pf-pro-co');if(tiv)currentUser.roleLabel=tiv;
  }
  P14_PROFILES[email]=p;
  applyRole();
  p14ToggleProfil(false);
  p14LoadProfil();
  if(typeof showToast==='function')showToast('Profil mis à jour ✓');
}
